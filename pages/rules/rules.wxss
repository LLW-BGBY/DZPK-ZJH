.rule-section{margin-bottom:24rpx;animation:slideUp 0.4s ease backwards}
.rule-section:nth-child(1){animation-delay:0.05s}
.rule-section:nth-child(2){animation-delay:0.1s}
.rule-section:nth-child(3){animation-delay:0.15s}
.rule-section:nth-child(4){animation-delay:0.2s}

.rule-heading{font-size:30rpx;font-weight:800;color:#f0d878;display:block;margin-bottom:12rpx;letter-spacing:1rpx}
.rule-body{font-size:26rpx;color:#c8d6c9;line-height:1.8;display:block;white-space:pre-line}

.hand-ranks{margin-top:16rpx}
.hand-item{display:flex;align-items:center;padding:12rpx 0;border-bottom:1rpx solid rgba(42,90,42,0.3);transition:all 0.2s ease}
.hand-item:active{background:rgba(240,216,120,0.05);border-radius:12rpx}
.hand-rank{width:48rpx;height:48rpx;border-radius:50%;background:linear-gradient(135deg,#e5c060,#f0d878);color:#0d1f0d;font-size:24rpx;font-weight:800;display:flex;align-items:center;justify-content:center;margin-right:16rpx;flex-shrink:0;box-shadow:0 2rpx 8rpx rgba(240,216,120,0.25)}
.hand-name{font-size:28rpx;color:#f0d878;font-weight:700;width:160rpx;flex-shrink:0}
.hand-desc{font-size:24rpx;color:#8a9a8e;flex:1}

@keyframes slideUp{from{opacity:0;transform:translateY(30rpx)}to{opacity:1;transform:translateY(0)}}
