.container{min-height:100vh;min-height:100dvh;background:radial-gradient(ellipse 120% 80% at 50% 30%,#1a5c3a 0%,#0f3d26 50%,#0a1f12 100%);padding:var(--page-pad-y) var(--page-pad-x);padding-bottom:var(--page-pad-bottom);max-width:var(--content-max-width);margin:0 auto;box-sizing:border-box}

.loading{display:flex;align-items:center;justify-content:center;height:40vh}
.loading-text{color:#f0d878;font-size:28rpx;animation:pulse 1.5s ease infinite}

/* Stats Card */
.stats-card{background:rgba(26,58,26,0.8);border:1px solid rgba(42,90,42,0.5);border-radius:24rpx;padding:32rpx;margin-bottom:24rpx;backdrop-filter:blur(8rpx);animation:fadeIn 0.4s ease}
.stats-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24rpx}
.stats-title{color:#f0d878;font-size:32rpx;font-weight:800}
.stats-level{color:#f0d878;font-size:24rpx;font-weight:700;background:rgba(240,216,120,0.12);padding:6rpx 16rpx;border-radius:12rpx;border:1px solid rgba(240,216,120,0.3)}
.stats-grid{display:flex;gap:16rpx}
.stat-item{flex:1;text-align:center;background:rgba(10,31,18,0.5);border-radius:16rpx;padding:20rpx 8rpx}
.stat-value{color:#fff;font-size:36rpx;font-weight:800;display:block}
.stat-value.text-gold{color:#f0d878}
.stat-label{color:#8a9a8e;font-size:20rpx;display:block;margin-top:4rpx}
.best-hand{text-align:center;margin-top:20rpx;padding-top:16rpx;border-top:1px solid rgba(42,90,42,0.4);color:#8a9a8e;font-size:24rpx}
.text-gold{color:#f0d878;font-weight:700}

/* Filter */
.filter-bar{padding:0 8rpx 16rpx}
.filter-title{color:#f0d878;font-size:28rpx;font-weight:700}

/* Daily List */
.daily-list{display:flex;flex-direction:column;gap:12rpx}
.daily-item{background:rgba(26,58,26,0.7);border:1px solid rgba(42,90,42,0.4);border-radius:16rpx;padding:20rpx;animation:slideUp 0.3s ease backwards}
.daily-item:nth-child(1){animation-delay:0.05s}
.daily-item:nth-child(2){animation-delay:0.1s}
.daily-item:nth-child(3){animation-delay:0.15s}
.daily-item:nth-child(4){animation-delay:0.2s}
.daily-item:nth-child(5){animation-delay:0.25s}
.daily-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx}
.daily-date{color:#fff;font-size:26rpx;font-weight:700}
.daily-profit{font-size:28rpx;font-weight:800}
.text-green{color:#00e5a0}
.text-red{color:#e74c3c}
.daily-detail{display:flex;gap:20rpx}
.detail-item{color:#8a9a8e;font-size:22rpx}

/* Empty */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80rpx 0;animation:fadeIn 0.4s ease}
.empty-icon{font-size:80rpx;margin-bottom:20rpx}
.empty-text{color:#8a9a8e;font-size:28rpx;display:block;margin-bottom:8rpx}
.empty-hint{color:#5a6a5e;font-size:22rpx}

@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(20rpx)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
