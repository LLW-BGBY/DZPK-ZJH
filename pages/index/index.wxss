.container{padding:var(--page-pad-y) var(--page-pad-x);padding-bottom:var(--page-pad-bottom);min-height:100vh;min-height:100dvh;background:radial-gradient(ellipse 120% 80% at 50% 20%,#0f3d26 0%,#0a1f12 60%,#060f08 100%);max-width:var(--content-max-width);margin:0 auto;box-sizing:border-box}

.hero{text-align:center;padding:48rpx 0 32rpx;animation:fadeIn 0.5s ease}
@media (max-width: 360px) {
  .hero{padding:32rpx 0 24rpx}
  .hero-icon{font-size:80rpx}
  .hero-title{font-size:48rpx}
  .mode-card{padding:24rpx;gap:16rpx}
}
.hero-icon{font-size:96rpx;display:block;margin-bottom:16rpx;animation:bounce 2.5s ease infinite;filter:drop-shadow(0 4rpx 12rpx rgba(240,216,120,0.3))}
.hero-title{color:#f0d878;font-size:56rpx;font-weight:800;display:block;letter-spacing:4rpx;background:linear-gradient(135deg,#f0d878 0%,#fff5d0 50%,#f0d878 100%);background-size:200% 100%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 4s linear infinite}
.hero-subtitle{color:#8a9a8e;font-size:28rpx;margin-top:8rpx;display:block}

.notice{background:rgba(26,58,26,0.7);border:1px solid rgba(42,90,42,0.5);border-radius:24rpx;padding:28rpx;margin-bottom:32rpx;backdrop-filter:blur(6rpx);animation:slideUp 0.4s ease}
.notice-title{color:#f0d878;font-size:28rpx;font-weight:700;display:block;margin-bottom:12rpx;letter-spacing:1rpx}
.notice-text{color:#8a9a8e;font-size:26rpx;line-height:1.6;display:block}
.notice-dots{display:flex;justify-content:center;gap:12rpx;margin-top:16rpx}
.dot{width:16rpx;height:16rpx;border-radius:50%;background:rgba(138,154,142,0.4);transition:all 0.2s ease}
.dot.active{background:#f0d878;transform:scale(1.2)}
.notice-static{border-left:4rpx solid #f0d878;border-radius:24rpx}

.mode-card{background:rgba(26,58,26,0.7);border:1px solid rgba(42,90,42,0.5);border-radius:32rpx;padding:32rpx;margin-bottom:20rpx;display:flex;align-items:center;gap:24rpx;transition:all 0.25s ease;backdrop-filter:blur(6rpx);animation:slideUp 0.4s ease backwards}
.mode-card:nth-child(1){animation-delay:0.1s}
.mode-card:nth-child(2){animation-delay:0.2s}
.mode-card:nth-child(3){animation-delay:0.3s}
.mode-card:active{transform:scale(0.98);border-color:rgba(240,216,120,0.3);box-shadow:0 0 16rpx rgba(240,216,120,0.1)}
.mode-icon{font-size:56rpx;width:96rpx;height:96rpx;background:linear-gradient(135deg,rgba(42,90,42,0.8),rgba(26,58,26,0.8));border-radius:24rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4rpx 12rpx rgba(0,0,0,0.3)}
.mode-info{flex:1}
.mode-title{color:#f0d878;font-size:32rpx;font-weight:700;display:block;margin-bottom:4rpx;letter-spacing:1rpx}
.mode-desc{color:#8a9a8e;font-size:26rpx;display:block}
.mode-arrow{color:#f0d878;font-size:40rpx;font-weight:300;transition:transform 0.2s ease}
.mode-card:active .mode-arrow{transform:translateX(8rpx)}

.join-card{border-color:rgba(240,216,120,0.15);background:rgba(26,58,26,0.5)}
.join-card .mode-icon{background:linear-gradient(135deg,rgba(42,90,42,0.5),rgba(26,58,26,0.5))}

.btn-share{background:transparent;color:#8a9a8e;border:1px solid rgba(42,90,42,0.5);border-radius:20rpx;padding:20rpx;font-size:28rpx;width:100%;margin-top:20rpx;transition:all 0.2s ease}
.btn-share:active{transform:scale(0.97);border-color:rgba(240,216,120,0.3)}

@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(30rpx)}to{opacity:1;transform:translateY(0)}}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-8rpx)}}