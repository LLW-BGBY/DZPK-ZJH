  font-size: 18rpx;
  font-weight: 700;
  max-width: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 2rpx;
}

.zjh-ring-chips {
  color: #f0d878;
  font-size: 16rpx;
  font-weight: 700;
  text-shadow: 0 1rpx 4rpx rgba(240, 216, 120, 0.3);
}

/* 下注筹码 - 头像卡片外部，顶部玩家显示在下方 */
.zjh-ring-bet {
  display: flex;
  align-items: center;
  gap: 3rpx;
  margin-top: 6rpx;
  padding: 3rpx 12rpx;
  background: linear-gradient(135deg, rgba(26, 46, 38, 0.88), rgba(14, 28, 20, 0.88));
  border: 1.5rpx solid rgba(45, 212, 150, 0.4);
  border-radius: 20rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

/* 左侧玩家：筹码显示在头像右边 */
.zjh-ring-seat .zjh-ring-bet-left {
  position: absolute;
  left: calc(50% + 53rpx);
  top: 4rpx;
  margin-top: 0;
  transform: none;
  z-index: 2;
}

/* 右侧玩家：筹码显示在头像左边 */
.zjh-ring-seat .zjh-ring-bet-right {
  position: absolute;
  right: calc(50% + 53rpx);
  top: 4rpx;
  margin-top: 0;
  transform: none;
  z-index: 2;
}

/* 筹码图标 */
.zjh-bet-chip-icon {
  font-size: 22rpx;
  line-height: 1;
}

/* 筹码数字 - 带动画 */
.zjh-bet-num {
  font-size: 18rpx;
  color: #f0d878;
  font-weight: 800;
  text-shadow: 0 1rpx 4rpx rgba(240, 216, 120, 0.3);
  animation: zjh-bet-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes zjh-bet-pop {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.25); opacity: 0.8; }
  100% { transform: scale(1); opacity: 1; }
}

.zjh-ring-rebuy {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  font-size: 12rpx;
  line-height: 1.2;
}

.zjh-ring-badge {
  color: #ff4444;
  font-size: 14rpx;
  font-weight: 700;
}

.zjh-ring-badge.badge-allin {
  color: #ff4444;
  font-size: 14rpx;
  font-weight: 800;
}

.zjh-ring-badge.badge-bust {
  color: #888;
  font-size: 14rpx;
}

/* ============================
   我方手牌模块 - 牌桌外部，操作区域上方
   ============================ */

/* 呼吸光效动画 */
@keyframes zjh-breathe-gold {
  0%, 100% {
    box-shadow: 0 0 0rpx rgba(240, 216, 120, 0), 0 0 0rpx rgba(240, 200, 80, 0);
  }
  50% {
    box-shadow: 0 0 20rpx rgba(240, 216, 120, 0.45), 0 0 40rpx rgba(240, 200, 80, 0.25);
  }
}

@keyframes zjh-breathe-card {
  0%, 100% {
    box-shadow: 0 0 6rpx rgba(240, 216, 120, 0.2), 0 4rpx 14rpx rgba(0, 0, 0, 0.5);
    border-color: rgba(240, 216, 120, 0.3);
  }
  50% {
    box-shadow: 0 0 18rpx rgba(240, 216, 120, 0.55), 0 0 35rpx rgba(240, 200, 80, 0.3), 0 4rpx 14rpx rgba(0, 0, 0, 0.5);
    border-color: rgba(240, 216, 120, 0.7);
  }
}

@keyframes zjh-breathe-btn {
  0%, 100% {
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3), 0 0 0rpx rgba(240, 216, 120, 0);
  }
  50% {
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3), 0 0 18rpx rgba(240, 216, 120, 0.5), 0 0 30rpx rgba(240, 200, 80, 0.25);
  }
}

.zjh-my-hand-wrap {
  position: absolute;
  bottom: 10rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: center;
  z-index: 20;
  box-sizing: border-box;
}

/* 我的头像卡 - 固定在左侧 */
.zjh-myhand-avatar-card {
  position: absolute;
  left: 12rpx;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rpx;
  padding: 4rpx 10rpx 6rpx;
  background: linear-gradient(160deg, rgba(20, 35, 25, 0.95), rgba(10, 22, 14, 0.95));
  border: 1.5px solid rgba(198, 162, 84, 0.3);
  border-radius: 12rpx;
  min-width: 80rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5), 0 0 0 1rpx rgba(0, 0, 0, 0.2);
  flex-shrink: 0;
}

.zjh-myhand-dealer-top {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: linear-gradient(135deg, #f0d878, #c6a254);
  color: #0d1f0d;
  font-size: 14rpx;
  font-weight: 800;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
  z-index: 5;
}

.zjh-myhand-avatar-main {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2px solid rgba(198, 162, 84, 0.5);
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
  transition: all 0.3s ease;
}

.zjh-myhand-avatar-main.zjh-avatar-main-active {
  border-color: #39e060;
  box-shadow:
    0 0 15rpx rgba(57, 224, 96, 0.6),
    0 0 30rpx rgba(57, 224, 96, 0.3);
  animation: zjh-avatar-pulse 2s infinite;
}

@keyframes zjh-avatar-pulse {
  0%, 100% {
    box-shadow:
      0 0 15rpx rgba(57, 224, 96, 0.6),
      0 0 30rpx rgba(57, 224, 96, 0.3);
  }
  50% {
    box-shadow:
      0 0 25rpx rgba(57, 224, 96, 0.8),
      0 0 50rpx rgba(57, 224, 96, 0.5);
  }
}

.zjh-myhand-avatar-card.zjh-avatar-active {
  box-shadow: 0 0 20rpx rgba(57, 224, 96, 0.3);
}

.zjh-myhand-avatar-main image {
  width: 100%;
  height: 100%;
  display: block;
}

.zjh-myhand-avatar-main text {
  font-size: 28rpx;
  line-height: 44rpx;
  display: block;
  text-align: center;
}

.zjh-myhand-name {
  color: rgba(255, 255, 255, 0.9);
  font-size: 16rpx;
  font-weight: 700;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 1rpx;
}

.zjh-myhand-chips-val {
  color: #f0d878;
  font-size: 14rpx;
  font-weight: 700;
  text-shadow: 0 1rpx 4rpx rgba(240, 216, 120, 0.3);
}

/* 己方下注筹码 - 浮在头像上方 */
.zjh-myhand-bet {
  position: absolute;
  left: 14rpx;
  top: -8rpx;
  display: flex;
  align-items: center;
  gap: 3rpx;
  margin-top: 0;
  padding: 3rpx 12rpx;
  background: linear-gradient(135deg, rgba(26, 46, 38, 0.88), rgba(14, 28, 20, 0.88));
  border: 1.5rpx solid rgba(45, 212, 150, 0.4);
  border-radius: 20rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  z-index: 5;
}

.zjh-myhand-bet .zjh-bet-chip-icon {
  font-size: 22rpx;
