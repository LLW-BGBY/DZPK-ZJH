}

/* 确认继续 */
.confirm-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(26, 29, 36, 0.5);
  border-radius: 16rpx;
  border: 1rpx solid rgba(42, 46, 56, 0.4);
}

.confirm-title {
  font-size: 26rpx;
  color: #f0d878;
