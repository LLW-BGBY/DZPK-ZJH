}

.zjh-my-rank-tag {
  color: #f0d878;
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 10rpx;
  background: linear-gradient(135deg, rgba(240, 216, 120, 0.15), rgba(200, 160, 60, 0.08));
  border-radius: 6rpx;
  border: 1px solid rgba(240, 216, 120, 0.3);
