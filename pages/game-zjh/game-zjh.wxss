}

.zjh-my-rebuy text {
  font-size: 12rpx;
}

/* 手牌 + 标签的右侧容器 */
.zjh-hand-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rpx;
  flex: 1;
  min-width: 0;
}

.zjh-handtag {
  display: flex;
