  color: #fff;
  font-size: 12rpx;
  font-weight: 700;
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  border: 1px solid #34495e;
  z-index: 10;
}

.zjh-ring-ming-badge {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  background: #e67e22;
  color: #fff;
  font-size: 12rpx;
  font-weight: 700;
  padding: 2rpx 6rpx;
  border-radius: 6rpx;
  border: 1px solid #f39c12;
  z-index: 10;
}

.zjh-ring-compare-badge {
  position: absolute;
  bottom: -4rpx;
