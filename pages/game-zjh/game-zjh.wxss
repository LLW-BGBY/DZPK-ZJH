}

.zjh-myhand-bet .zjh-bet-num {
  font-size: 18rpx;
  color: #f0d878;
  font-weight: 800;
  text-shadow: 0 1rpx 4rpx rgba(240, 216, 120, 0.3);
  animation: zjh-bet-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.zjh-my-rebuy {
