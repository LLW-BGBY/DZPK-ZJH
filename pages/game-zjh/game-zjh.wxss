/* ============================
   炸金花 游戏页面样式 - 独立完整版
   ============================ */

/* 小程序页面根元素 - 必须设置，否则子元素 height: 100% 不生效 */
page {
  height: 100%;
  width: 100%;
  background-color: var(--felt-deep);
}

/* ============================================================
   基础布局 & 加载/错误/过渡
   ============================================================ */

/* 根容器 - flex 列布局，确保 header + game 不超出屏幕 */
.zjh-root {
  width: 100%;
  height: 100vh;
  background-color: var(--felt-deep);
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 游戏主界面 - 占据 header 之外的剩余空间 */
.zjh-game {
  width: 100%;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background-color: var(--felt-deep);
  overflow: visible;
}

.zjh-spectator-bar {
  text-align: center;
  padding: 8rpx 0;
  margin: 8rpx 20rpx 0;
  background: linear-gradient(180deg, rgba(255, 200, 80, 0.2), rgba(255, 160, 0, 0.15));
  border: 1px solid rgba(255, 200, 80, 0.4);
  border-radius: 10rpx;
}
.zjh-spectator-bar text {
  font-size: 24rpx;
  font-weight: 600;
  color: #f0d878;
}

.loading {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #a0a6b0;
}

.error-box {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #a0a6b0;
  font-size: 28rpx;
}

.btn-sm {
  background: rgba(240, 216, 120, 0.12);
  color: #f0d878;
  border: 1rpx solid rgba(240, 216, 120, 0.3);
  border-radius: 20rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  margin: 6rpx;
}

.transition-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.transition-overlay.show {
  opacity: 1;
}

.transition-deal {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.zjh-deal-card {
  width: 90rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #fff 0%, #e8dcc8 100%);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.5);
  animation: zjh-card-deal 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  transform: rotateY(90deg);
}

.zjh-deal-card-txt {
  font-size: 50rpx;
}

@keyframes zjh-card-deal {
  0% { transform: rotateY(90deg) scale(0.5); opacity: 0; }
  60% { transform: rotateY(-10deg) scale(1.05); opacity: 1; }
  100% { transform: rotateY(0deg) scale(1); opacity: 1; }
}

.transition-title {
  font-size: 32rpx;
  color: #f0d878;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.transition-dots {
  display: flex;
  gap: 12rpx;
}

.zjh-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f0d878;
  animation: zjh-dot-bounce 0.8s ease infinite alternate;
}

@keyframes zjh-dot-bounce {
  0% { transform: translateY(0); opacity: 0.4; }
  100% { transform: translateY(-16rpx); opacity: 1; }
}

/* ============================================================
   等待界面
   ============================================================ */
.wait-area {
  width: 100%;
  height: 100vh;
  background-color: var(--felt-deep);
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow: hidden;
}

.wait-scroll {
  flex: 1;
  width: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 20rpx;
}

.wait-room-card {
  width: 100%;
  background: linear-gradient(145deg, rgba(20, 40, 28, 0.85), rgba(10, 25, 18, 0.9));
  border: 2rpx solid rgba(198, 162, 84, 0.2);
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.wait-room-compact-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.wait-room-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.wait-room-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.wait-room-lock {
  font-size: 24rpx;
}

.wait-room-num-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(20, 40, 28, 0.6);
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
}

.wait-room-num {
  font-size: 26rpx;
  color: #a0a6b0;
  font-family: monospace;
}

.wait-room-copy {
  font-size: 22rpx;
  color: #60b8ff;
}

.wait-room-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  font-size: 24rpx;
  color: #a0a6b0;
  margin-bottom: 20rpx;
}

.wait-meta-dot {
  color: rgba(198, 162, 84, 0.4);
}

.zjh-game-type-badge {
  color: var(--gold);
  font-weight: 700;
}

.wait-action-row {
  display: flex;
  gap: 16rpx;
}

.wait-action-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  padding: 0;
  border: none;
}

.wait-action-invite {
  background: #1e3a5f;
  color: #60b8ff;
}

.wait-action-leave {
  background: #3a1e20;
  color: #ff6b6b;
}

.wait-action-icon {
  font-size: 28rpx;
}

.wait-action-label {
  font-size: 26rpx;
}

.wait-section-title {
  font-size: 26rpx;
  color: #8a9a8e;
  font-weight: 600;
  margin-bottom: 16rpx;
  align-self: flex-start;
  display: block;
}

.wait-list {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.wait-card {
  width: calc(33.33% - 12rpx);
  background: linear-gradient(145deg, rgba(20, 40, 28, 0.85), rgba(10, 25, 18, 0.9));
  border: 2rpx solid rgba(198, 162, 84, 0.2);
  border-radius: 18rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.wait-card.ready {
  border-color: #39e060;
  box-shadow: 0 0 12rpx rgba(57, 224, 96, 0.25);
}

.wait-card.bust {
  opacity: 0.5;
}

.wait-card.empty {
  background: rgba(10, 31, 18, 0.4);
  border-style: dashed;
  border-color: rgba(198, 162, 84, 0.15);
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(198, 162, 84, 0.4);
  background: linear-gradient(135deg, #3a6a4e 0%, #2a4a38 100%);
  overflow: hidden;
}

.avatar-txt {
  font-size: 36rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3a6a4e 0%, #2a4a38 100%);
  border: 2rpx solid rgba(198, 162, 84, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gold);
}

.name {
  font-size: 24rpx;
  color: #d1d5db;
  font-weight: 600;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chips {
  font-size: 22rpx;
  color: var(--gold);
  font-weight: 700;
}

.bust {
  font-size: 22rpx;
  color: #e74c3c;
  font-weight: 600;
}

.ready-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  background: rgba(42, 74, 54, 0.5);
  color: #8a9a8e;
  border: 1rpx solid rgba(42, 90, 42, 0.3);
}

.ready-badge.done {
  background: rgba(46, 204, 113, 0.15);
  color: #2ecc71;
  border-color: rgba(46, 204, 113, 0.3);
}

.wait-chat-log {
  width: 100%;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.wait-chat-title {
  font-size: 24rpx;
  color: #8a9a8e;
  margin-bottom: 8rpx;
  display: block;
}

.wait-chat-scroll {
  max-height: 120rpx;
  background: rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(198, 162, 84, 0.1);
  border-radius: 12rpx;
  padding: 8rpx 12rpx;
}

.wait-chat-item {
  padding: 3rpx 0;
  font-size: 22rpx;
  line-height: 1.5;
}

.wait-chat-name {
  color: var(--gold);
  font-weight: 700;
}

.wait-chat-text {
  color: rgba(255, 255, 255, 0.7);
}

.wait-bottom {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
  padding-bottom: 24rpx;
}

/* 等待界面按钮 */
.btn-ready {
  width: 100%;
  height: 88rpx;
  background: #2a4a36;
  border-radius: 20rpx;
  color: #39e060;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.btn-ready.done {
  background: #1e3a28;
  color: #a0a6b0;
}

.btn-rebuy {
  width: 100%;
  height: 80rpx;
  background: rgba(240, 216, 120, 0.12);
  border: 1rpx solid rgba(240, 216, 120, 0.3);
  border-radius: 20rpx;
  color: var(--gold);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-chat {
  width: 100%;
  height: 80rpx;
  background: rgba(26, 58, 26, 0.6);
  border: 1rpx solid rgba(42, 90, 42, 0.4);
  border-radius: 20rpx;
  color: #c8d8c8;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0;
}

.chat-unread-badge {
  position: absolute;
  top: 12rpx;
  right: 32rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-start {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1e3a5f 0%, #2a4a7a 100%);
  border-radius: 20rpx;
  color: #60b8ff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.inline-countdown {
  width: 100%;
  padding: 16rpx 20rpx;
  background: rgba(240, 216, 120, 0.1);
  border: 1rpx solid rgba(240, 216, 120, 0.3);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.inline-countdown-icon {
  font-size: 28rpx;
}

.inline-countdown-label {
  font-size: 26rpx;
  color: var(--gold);
  font-weight: 600;
}

.countdown-cancel-btn {
  font-size: 24rpx;
  color: #ff6b6b;
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 107, 107, 0.15);
  border-radius: 10rpx;
}

/* ============================
   聊天弹窗面板
   ============================ */
.chat-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(10, 22, 14, 0.98), rgba(5, 15, 8, 0.99));
  border-top: 1rpx solid rgba(198, 162, 84, 0.2);
  border-radius: 24rpx 24rpx 0 0;
  padding: 20rpx 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.chat-panel.show {
  transform: translateY(0);
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.chat-title {
  font-size: 30rpx;
  color: #f0d878;
  font-weight: 700;
}

.chat-close {
  font-size: 32rpx;
  color: #8a9a8e;
  padding: 8rpx 12rpx;
}

.quick-msgs {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.quick-msg {
  background: rgba(26, 58, 26, 0.6);
  border: 1rpx solid rgba(198, 162, 84, 0.15);
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
}

.quick-msg text {
  font-size: 22rpx;
  color: #c8d0c8;
}

.chat-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: rgba(26, 58, 26, 0.5);
  border: 1rpx solid rgba(198, 162, 84, 0.15);
  border-radius: 14rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.chat-send {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #2a6a4a, #1a4a32);
  border: none;
  border-radius: 14rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.btn-start {
  width: 100%;
  height: 88rpx;
  background: #1e3a5f;
  border-radius: 20rpx;
  color: #60b8ff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: none;
  padding: 0;
}

.inline-countdown {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx;
  background: rgba(240, 216, 120, 0.08);
  border-radius: 14rpx;
  border: 1rpx solid rgba(240, 216, 120, 0.15);
  margin-bottom: 12rpx;
}

.inline-countdown-icon {
  font-size: 28rpx;
}

.inline-countdown-label {
  font-size: 24rpx;
  color: #f0d878;
  font-weight: 600;
}

.countdown-cancel-btn {
  background: rgba(231, 76, 60, 0.2);
  border: 1rpx solid rgba(231, 76, 60, 0.3);
  border-radius: 10rpx;
  color: #e74c3c;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  margin-left: 12rpx;
}

/* ============================================================
   游戏界面 - 本玩家区域
   ============================================================ */
.game-my-section {
  width: 100%;
  padding: 8rpx 20rpx 16rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(180deg, rgba(10, 31, 18, 0.3), rgba(5, 20, 12, 0.6));
  border-top: 1rpx solid rgba(198, 162, 84, 0.1);
}

.my-info-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 8rpx 14rpx;
  background: rgba(26, 58, 26, 0.5);
  border: 1px solid rgba(198, 162, 84, 0.12);
  border-radius: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.my-call {
  font-size: 22rpx;
  color: #f0d878;
  font-weight: 600;
}

.my-turn {
  font-size: 22rpx;
  color: #00e5a0;
  font-weight: 700;
  animation: pulse 1s ease infinite;
}

.my-holes {
  display: flex;
  align-items: center;
  gap: 12rpx;
  position: relative;
}

.hcard {
  width: 80rpx;
  height: 110rpx;
  border-radius: 10rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border: 2rpx solid rgba(198, 162, 84, 0.3);
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.35);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.hcard.red {
  color: #c41e3a;
}

.hcard.black {
  color: #1a1a1a;
}

.hv {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.hs {
  font-size: 30rpx;
  line-height: 1;
  margin-top: 2rpx;
  font-weight: 700;
}

/* ============================================================
   操作按钮区
   ============================================================ */
.actions {
  width: 100%;
  padding: 8rpx 20rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  background: linear-gradient(180deg, rgba(5, 20, 12, 0.6), rgba(5, 20, 12, 0.95));
  border-top: 1rpx solid rgba(198, 162, 84, 0.1);
}

.actions-row {
  display: flex;
  gap: 10rpx;
  width: 100%;
}

.abtn {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(26, 58, 26, 0.6);
  padding: 0;
  transition: all 0.15s ease;
}

.abtn:active {
  transform: scale(0.95);
}

.abtn[disabled] {
  opacity: 0.5;
}

.abtn.fold {
  background: linear-gradient(180deg, rgba(42, 74, 122, 0.8), rgba(30, 58, 95, 0.9));
  border-color: rgba(100, 140, 180, 0.2);
}

.abtn.call {
  background: linear-gradient(180deg, rgba(46, 100, 62, 0.8), rgba(32, 72, 44, 0.9));
  border-color: rgba(100, 180, 120, 0.2);
}

.abtn.raise {
  background: linear-gradient(180deg, rgba(122, 61, 61, 0.8), rgba(90, 42, 42, 0.9));
  border-color: rgba(200, 120, 120, 0.2);
}

.abtn.allin {
  background: linear-gradient(135deg, #c41e3a, #8b0000);
  border-color: rgba(255, 60, 60, 0.4);
  box-shadow: 0 0 16rpx rgba(196, 30, 58, 0.3);
}

.abtn.done {
  background: rgba(42, 90, 42, 0.4) !important;
  border-color: rgba(46, 204, 113, 0.3) !important;
  color: #2ecc71 !important;
}

/* ============================================================
   结算界面
   ============================================================ */
.end-box {
  width: 100%;
  padding: 24rpx 20rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hand-info-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 10rpx;
  background: rgba(26, 29, 36, 0.6);
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 46, 56, 0.4);
}

.hand-info-text {
  font-size: 24rpx;
  color: #a0a6b0;
  font-weight: 600;
}

.hand-info-final {
  font-size: 22rpx;
  color: #f0d878;
  font-weight: 700;
  background: rgba(240, 216, 120, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.end-title {
  font-size: 36rpx;
  color: #f0d878;
  font-weight: 800;
  text-align: center;
}

/* 实时聊天 */
.game-live-chat {
  width: 100%;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  overflow: hidden;
}

.live-chat-scroll {
  max-height: 120rpx;
  padding: 8rpx 12rpx;
}

.live-chat-item {
  padding: 3rpx 0;
  font-size: 22rpx;
  line-height: 1.5;
}

.live-chat-name {
  color: #00ffb3;
  font-weight: 700;
}

.live-chat-text {
  color: rgba(255, 255, 255, 0.7);
}

/* 摊牌 */
.hand-reveal {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hr-title {
  font-size: 28rpx;
  color: #f0d878;
  font-weight: 700;
  text-align: center;
  padding: 8rpx 0;
