}

/* ============================================================
   炸金花特有样式
   ============================================================ */

/* 暗牌卡背样式（对齐德州扑克白底卡牌，暗牌时显示蓝底花纹） */
.zjh-card-dark {
  background: linear-gradient(135deg, #1a3a5c, #2a5298) !important;
  border: 2px solid rgba(200, 180, 100, 0.5) !important;
  color: transparent !important;
  position: relative;
  overflow: hidden;
}

.zjh-card-back-pattern {
  width: 100%;
  height: 100%;
  background: 
    repeating-linear-gradient(45deg, transparent, transparent 4rpx, rgba(255,255,255,0.08) 4rpx, rgba(255,255,255,0.08) 8rpx),
    repeating-linear-gradient(-45deg, transparent, transparent 4rpx, rgba(255,255,255,0.08) 4rpx, rgba(255,255,255,0.08) 8rpx);
  border-radius: 10rpx;
  position: relative;
}

.zjh-card-back-pattern::after {
  content: '🂠';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  color: rgba(255,255,255,0.3);
}

/* 游戏类型标签 */
.zjh-game-type-badge {
  background: linear-gradient(135deg, #e67e22, #d35400);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  letter-spacing: 1rpx;
}

/* 暗/明状态标签 — 与 D 徽章完全相同结构 */
.zjh-status-dark {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  background: #2c3e50;
  color: #bdc3c7;
  font-size: 14rpx;
  font-weight: 700;
  min-width: 26rpx;
  height: 26rpx;
  line-height: 26rpx;
  padding: 0 4rpx;
  border-radius: 6rpx;
  border: 1px solid #34495e;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.zjh-status-ming {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  background: #e67e22;
  color: #fff;
  font-size: 14rpx;
  font-weight: 700;
  min-width: 26rpx;
  height: 26rpx;
  line-height: 26rpx;
  padding: 0 4rpx;
  border-radius: 6rpx;
  border: 1px solid #f39c12;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

/* 本玩家暗/明标签 */
.zjh-my-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.zjh-my-dark-label {
  background: #2c3e50;
  color: #bdc3c7;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  border: 1px solid #34495e;
}

.zjh-my-ming-label {
  background: #e67e22;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  border: 1px solid #f39c12;
}

/* ============================
   牌桌区域 - 围桌分布（参考德州扑克）
   ============================ */

/* 桌面环形区域容器 */
.zjh-table-wrap {
  flex: 1;
  min-height: 0;
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 28rpx 0 0;
  overflow: visible;
  box-sizing: border-box;
}

/* 竖椭圆牌桌 - 手牌在牌桌内 */
.zjh-table-oval {
  position: relative;
  width: 82%;
  flex: 1;
  min-height: 200rpx;
  height: 100%;
  max-height: 70vh;
  background:
    radial-gradient(ellipse 90% 90% at 50% 50%,
      #1a6b3c 0%, #145a30 40%, #0d3d1f 75%, #0a2a14 100%);
  border: 8rpx solid #6b4c3b;
  border-radius: 150rpx;
  box-shadow:
    0 0 8rpx rgba(0, 0, 0, 0.4) inset,
    0 0 60rpx rgba(0, 0, 0, 0.5) inset,
    0 0 24rpx rgba(198, 162, 84, 0.15),
    inset 0 0 0 4rpx rgba(255, 255, 255, 0.04),
    inset 0 0 0 14rpx rgba(255, 255, 255, 0.02);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 44rpx;
  padding-bottom: 20rpx;
  z-index: 1;
  overflow: visible;
}

/* 牌桌中央区域容器：底池 + 倒计时 + 日志 + 聊天 - 牌桌上部 */
.zjh-center-area {
  position: absolute;
  top: 20%;
  left: 50%;
  transform: translate(-50%, 0);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  z-index: 3;
  width: 88%;
}

/* 牌桌内房间信息条 */
.zjh-table-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

/* 底池 - 最上方 */
.zjh-pot-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  position: relative;
}

.zjh-pot-icon {
  font-size: 36rpx;
  animation: zjh-coin-bounce 1.5s ease infinite;
}

@keyframes zjh-coin-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.zjh-pot-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #f0d878;
  text-shadow:
    0 0 20rpx rgba(240, 216, 120, 0.6),
    0 0 40rpx rgba(240, 216, 120, 0.3),
    0 2rpx 10rpx rgba(240, 216, 120, 0.5);
  line-height: 1;
  transition: all 0.3s ease;
}

.zjh-pot-num.pot-animate {
  animation: zjh-pot-linear-jump 0.5s linear;
}

/* 线性数字跳动动画 */
@keyframes zjh-pot-linear-jump {
  0%   { transform: translateY(0); }
  25%  { transform: translateY(-6rpx); }
  50%  { transform: translateY(0); }
  75%  { transform: translateY(-4rpx); }
  100% { transform: translateY(0); }
}

/* 阶段信息 - 底池下方 */
.zjh-phase-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  position: relative;
  margin-top: 2rpx;
}

/* 牌桌日志 - 阶段信息下方 */
.zjh-table-log {
  max-height: 150rpx;
  width: 100%;
  padding: 6rpx 12rpx;
  background: none;
  border-radius: 0;
  border: none;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  box-sizing: border-box;
}

/* 牌桌聊天框 - 日志下方 */
.zjh-table-chat {
  max-height: 150rpx;
  width: 100%;
  padding: 6rpx 12rpx;
  margin-top: 12rpx;
  background: none;
  border-radius: 0;
  border: none;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  box-sizing: border-box;
}

.zjh-phase-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.zjh-countdown-txt {
  font-size: 26rpx;
  color: #f0d878;
  font-weight: 700;
  animation: zjh_pulse 1s ease infinite;
}

.zjh-waiting-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 牌桌水印 - 中央区域背景 */
.zjh-table-watermark {
  position: absolute;
  top: 20%;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  opacity: 0.22;
  pointer-events: none;
  z-index: 2;
}

.zjh-watermark-desc {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

.zjh-watermark-brand {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.zjh-brand-icon {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
}

.zjh-brand-text {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 500;
}

/* 本玩家信息栏 - 带底 bar */
.game-my-section {
  padding: 6rpx 20rpx 10rpx !important;
  background: linear-gradient(180deg, rgba(10, 31, 18, 0.2), rgba(5, 20, 12, 0.5)) !important;
  border-top: 1rpx solid rgba(198, 162, 84, 0.08) !important;
}

.zjh-my-row {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
}

.zjh-my-avatar-wrap {
  position: absolute;
  left: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  padding: 8rpx 10rpx;
  background: linear-gradient(160deg, rgba(20, 35, 25, 0.92), rgba(10, 22, 14, 0.92));
  border: 2px solid rgba(240, 216, 120, 0.45);
  border-radius: 16rpx;
  box-shadow: 0 0 20rpx rgba(240, 216, 120, 0.25), 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
  min-width: 90rpx;
  z-index: 2;
}

.zjh-my-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2px solid rgba(240, 216, 120, 0.6);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.zjh-my-avatar-txt {
  font-size: 44rpx;
  line-height: 1;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(26, 58, 26, 0.8);
  border: 2px solid rgba(240, 216, 120, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.zjh-my-avatar-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
}

.zjh-my-avatar-badge.d-badge {
  background: linear-gradient(135deg, #f0d878, #c6a254);
  color: #0d1f0d;
  font-size: 16rpx;
  font-weight: 800;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}

.zjh-my-chips {
  font-size: 22rpx;
  color: #f0d878;
  font-weight: 700;
  text-shadow: 0 1rpx 4rpx rgba(240, 216, 120, 0.3);
}

.game-my-section .my-info-bar {
  background: linear-gradient(135deg, rgba(26, 58, 26, 0.7), rgba(10, 31, 18, 0.5));
  border: 1px solid rgba(198, 162, 84, 0.15);
  border-radius: 10rpx;
  padding: 8rpx 14rpx;
  margin-bottom: 6rpx;
}

/* 围桌玩家卡片 - 弹性定位 */
.zjh-opp-card {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3rpx;
  z-index: 2;
  padding: 8rpx 14rpx;
  background: linear-gradient(160deg, rgba(20, 35, 25, 0.92), rgba(10, 22, 14, 0.92));
  border: 1.5px solid rgba(198, 162, 84, 0.25);
  border-radius: 14rpx;
  min-width: 100rpx;
  text-align: center;
  transition: all 0.3s ease;
  transform: translate(-50%, -50%);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
}

.zjh-opp-card.active {
  border-color: #00e5a0;
  box-shadow: 0 0 20rpx rgba(0, 229, 160, 0.5), 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
}

.zjh-opp-card.fold {
  opacity: 0.35;
  filter: grayscale(0.7);
}

.zjh-opp-card.allin {
  border-color: #c41e3a;
  box-shadow: 0 0 20rpx rgba(196, 30, 58, 0.5), 0 4rpx 12rpx rgba(0, 0, 0, 0.35);
}

.zjh-opp-av-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
}

.zjh-opp-av {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: block;
  border: 2px solid rgba(198, 162, 84, 0.4);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.zjh-opp-av-txt {
  font-size: 38rpx;
  line-height: 1;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(26, 58, 26, 0.8);
  border: 2px solid rgba(198, 162, 84, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.zjh-opp-name {
  color: rgba(255, 255, 255, 0.9);
  font-size: 20rpx;
  font-weight: 700;
  max-width: 90rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zjh-opp-chips {
  color: #f0d878;
  font-size: 18rpx;
  font-weight: 700;
  text-shadow: 0 1rpx 4rpx rgba(240, 216, 120, 0.3);
}

.zjh-opp-allin {
  color: #ff4444;
  font-size: 16rpx;
  font-weight: 800;
}

.zjh-opp-bust {
  color: #ff4444;
  font-size: 16rpx;
  font-weight: 700;
}

.zjh-opp-lost {
  color: #888;
  font-size: 16rpx;
}

.zjh-opp-badge {
  position: absolute;
}

.zjh-opp-badge.d-badge {
  top: -2rpx;
  right: -2rpx;
  background: linear-gradient(135deg, #f0d878, #c6a254);
  color: #0d1f0d;
  font-size: 16rpx;
  font-weight: 800;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
}

.zjh-opp-badge.zjh-compare-badge {
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255, 165, 0, 0.95);
  color: #fff;
  font-size: 14rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

/* 重买图标 - 卡片右侧竖排 */
.zjh-rebuy-icons {
  position: absolute;
  right: 6rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 0;
  font-size: 18rpx;
  line-height: 1.2;
}

/* 自己 - 突出显示 */
.zjh-is-self {
  border-color: #f0d878 !important;
  border-width: 2px !important;
  box-shadow: 0 0 24rpx rgba(240, 216, 120, 0.45), 0 4rpx 12rpx rgba(0, 0, 0, 0.35) !important;
  background: linear-gradient(160deg, rgba(30, 50, 30, 0.95), rgba(15, 30, 18, 0.95)) !important;
  min-width: 110rpx;
  padding: 10rpx 16rpx !important;
  z-index: 3;
}

.zjh-is-self .zjh-opp-av {
  width: 56rpx;
  height: 56rpx;
  border-color: rgba(240, 216, 120, 0.6);
}

.zjh-is-self .zjh-opp-av-txt {
  font-size: 42rpx;
  width: 56rpx;
  height: 56rpx;
}

.zjh-is-self .zjh-opp-name {
  font-size: 22rpx;
  color: #f0d878;
}

.zjh-is-self .zjh-opp-chips {
  font-size: 20rpx;
}

/* ============================
   环形座位 - 参考德州扑克设计
   ============================ */
.zjh-ring-seat {
  position: absolute;
  z-index: 5;
  transform: translate(-50%, -50%);
}

.zjh-ring-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  padding: 4rpx 8rpx 6rpx;
  background: linear-gradient(160deg, rgba(20, 35, 25, 0.95), rgba(10, 22, 14, 0.95));
  border: 1.5px solid rgba(198, 162, 84, 0.3);
  border-radius: 12rpx;
  min-width: 80rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5), 0 0 0 1rpx rgba(0, 0, 0, 0.2);
  position: relative;
}

.zjh-ring-card.active {
  border-color: #00e5a0;
  box-shadow: 0 0 28rpx rgba(0, 229, 160, 0.6), 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
}

.zjh-ring-card.fold {
  opacity: 0.35;
  filter: grayscale(0.7);
}

.zjh-ring-card.zjh-out-player {
  opacity: 0.35;
  filter: grayscale(0.7);
}

.zjh-ring-card.allin {
  border-color: #c41e3a;
  box-shadow: 0 0 28rpx rgba(196, 30, 58, 0.6), 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
}

.zjh-ring-dealer {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: linear-gradient(135deg, #f0d878, #c6a254);
  color: #0d1f0d;
  font-size: 16rpx;
  font-weight: 800;
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
  z-index: 5;
}

.zjh-ring-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2px solid rgba(198, 162, 84, 0.5);
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.4);
}

.zjh-ring-avatar image {
  width: 100%;
  height: 100%;
