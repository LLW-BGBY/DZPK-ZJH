  border: 1px solid rgba(0, 229, 160, 0.3);
  animation: zjh-turn-pulse 1.5s ease infinite;
}

@keyframes zjh-turn-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.zjh-myhand-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

/* 旧的手牌左侧头像样式 - 保留兼容但不再使用 */
.zjh-myhand-avatar {
  display: none;
}

.zjh-myhand-cards {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.zjh-hand-card {
  width: 88rpx;
  height: 120rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.5);
}

.zjh-hand-card.black {
  background: linear-gradient(135deg, #ffffff, #f0f0f0);
  color: #1a1a2e;
  border: 1.5px solid #ccc;
}

.zjh-hand-card.red {
  background: linear-gradient(135deg, #ffffff, #fef0f0);
  color: #c0392b;
  border: 1.5px solid #e8c4c4;
}

.zjh-hand-card.hand-red {
  color: #c0392b;
}

.zjh-card-dark {
  background: linear-gradient(135deg, #1a3a6b, #0d1f3c);
  border: 1.5px solid #2a5a9b;
}

.zjh-card-back-pattern {
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 3rpx,
    rgba(255, 255, 255, 0.1) 3rpx,
    rgba(255, 255, 255, 0.1) 6rpx
  );
  border-radius: 10rpx;
}

.zjh-hand-card-value {
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.1;
}

.zjh-hand-card-suit {
  font-size: 24rpx;
  line-height: 1.1;
}

/* 轮到我的回合 - 手牌呼吸光效（仅手牌本身，外框不发光） */
.zjh-my-hand-wrap.zjh-my-turn .zjh-hand-card {
  animation: zjh-breathe-card 1.5s ease-in-out infinite;
}

/* 聊天按钮 - 牌桌右下角 */
.zjh-table-chat-btn {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  width: 72rpx;
  height: 50rpx;
  padding: 0;
  box-sizing: border-box;
  background: linear-gradient(135deg, rgba(26, 58, 26, 0.7), rgba(10, 31, 18, 0.5));
  border: 1.5px solid rgba(198, 162, 84, 0.25);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  z-index: 25;
}

/* ============================
   操作按钮区 - 参考德州扑克
   ============================ */
.zjh-action-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 100;
  flex-shrink: 0;
  flex-grow: 0;
  background: linear-gradient(180deg, rgba(10, 31, 18, 0.95), rgba(5, 20, 12, 0.98));
  border-top: 1rpx solid rgba(198, 162, 84, 0.12);
}

/* 轮到我的回合 - 操作区呼吸光效（仅按钮，外框不发光） */
.zjh-action-wrap.zjh-my-turn .zjh-action-btn {
  animation: zjh-breathe-btn 1.5s ease-in-out infinite;
}

/* 快捷倍率 + 滑块 */
.zjh-slider-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: transparent;
  height: 50rpx;
}

.zjh-ratio-btn {
  background: rgba(15, 40, 28, 0.6);
  border: 1rpx solid rgba(198, 162, 84, 0.15);
  border-radius: 10rpx;
  padding: 6rpx 14rpx;
  flex-shrink: 0;
}

.zjh-ratio-btn text {
  font-size: 22rpx;
  color: #a0a6b0;
  font-weight: 700;
}

.zjh-ratio-btn.active {
  background: #2a6a4a;
  border-color: #3a8a5a;
}

.zjh-ratio-btn.active text {
  color: #ffffff;
}

.zjh-slider {
  flex: 1;
  margin-left: 10rpx;
  margin-top: 0;
}

.zjh-action-row {
  display: flex;
  gap: 6rpx;
  width: 100%;
}

.zjh-action-btn {
  flex: 1;
  height: 56rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  transition: all 0.15s ease;
  border: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  padding: 0 6rpx;
}

.zjh-action-btn:active {
  transform: scale(0.96);
}

.zjh-action-btn.action-fold {
  background: linear-gradient(180deg, rgba(42, 74, 122, 0.8), rgba(30, 58, 95, 0.9));
  border: 1px solid rgba(100, 140, 180, 0.2);
  color: #b0c8e0;
}

.zjh-action-btn.action-see {
  background: linear-gradient(180deg, rgba(122, 90, 42, 0.8), rgba(95, 65, 30, 0.9));
  border: 1px solid rgba(180, 150, 100, 0.2);
  color: #e0c890;
}

.zjh-action-btn.action-call {
  background: linear-gradient(180deg, rgba(46, 100, 62, 0.8), rgba(32, 72, 44, 0.9));
  border: 1px solid rgba(100, 180, 120, 0.2);
  color: #b0e0c0;
}

.zjh-action-btn.action-raise {
  background: linear-gradient(180deg, rgba(122, 61, 61, 0.8), rgba(90, 42, 42, 0.9));
  border: 1px solid rgba(200, 120, 120, 0.2);
  color: #e0b0b0;
}

.zjh-action-btn.action-compare {
  background: linear-gradient(180deg, rgba(100, 70, 20, 0.8), rgba(70, 50, 15, 0.9));
  border: 1px solid rgba(180, 140, 60, 0.2);
  color: #e0c880;
}

.zjh-action-btn.action-allin {
  background: linear-gradient(180deg, rgba(140, 30, 30, 0.8), rgba(100, 20, 20, 0.9));
  border: 1px solid rgba(220, 80, 80, 0.2);
  color: #ffb0b0;
}

.zjh-action-btn.done {
  opacity: 0.5;
  filter: grayscale(0.3);
}

