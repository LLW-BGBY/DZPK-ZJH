  border: 2px solid rgba(198, 162, 84, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hr-rebuy-icons {
  position: absolute;
  right: 8rpx;
  top: 6rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  font-size: 16rpx;
