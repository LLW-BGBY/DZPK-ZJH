.zjh-gh-info {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.zjh-gh-info.zjh-cap-warning {
  color: #e74c3c;
  font-weight: 700;
  animation: zjh_pulse 1s ease infinite;
}

.zjh-gh-sep {
  color: rgba(255, 255, 255, 0.12);
  font-size: 16rpx;
}

.zjh-gh-badge {
  background: linear-gradient(135deg, rgba(198, 162, 84, 0.3), rgba(198, 162, 84, 0.1));
  border: 1px solid rgba(198, 162, 84, 0.35);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  font-size: 20rpx;
  color: #e0c878;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.zjh-gh-right {
  flex-shrink: 0;
}

.zjh-gh-leave {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  font-weight: 700;
  background: linear-gradient(180deg, rgba(160, 60, 60, 0.5), rgba(120, 40, 40, 0.6));
  border: 1px solid rgba(200, 100, 100, 0.25);
  border-radius: 10rpx;
  color: #ffc8c8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ============================================================
   横向玩家状态条
   ============================================================ */
.zjh-pos-bar {
  width: 100%;
  white-space: nowrap;
  padding: 8rpx 12rpx;
  background: rgba(10, 20, 15, 0.85);
  border-bottom: 1rpx solid rgba(198, 162, 84, 0.12);
  box-sizing: border-box;
  flex-shrink: 0;
}

.zjh-pos-bar::-webkit-scrollbar {
  display: none;
}

.zjh-pos-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  margin-right: 8rpx;
  background: rgba(26, 58, 26, 0.4);
  border: 1rpx solid rgba(42, 90, 42, 0.2);
  border-radius: 10rpx;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.zjh-pos-item.active {
  background: rgba(0, 229, 160, 0.15);
  border-color: #00e5a0;
  box-shadow: 0 0 12rpx rgba(0, 229, 160, 0.3);
}

.zjh-pos-item.folded {
  opacity: 0.45;
  background: rgba(40, 40, 40, 0.4);
  border-color: rgba(80, 80, 80, 0.2);
}

.zjh-pos-item.busted {
  opacity: 0.4;
  background: rgba(60, 20, 20, 0.4);
  border-color: rgba(120, 40, 40, 0.2);
}

.zjh-pos-name {
  font-size: 22rpx;
  color: #d1d5db;
  font-weight: 600;
}

.zjh-pos-item.active .zjh-pos-name {
  color: #00e5a0;
}

.zjh-pos-status {
  font-size: 18rpx;
  color: #8a9a8e;
  padding: 2rpx 8rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 6rpx;
}

.zjh-pos-status.dealer {
  color: #f0d878;
  background: rgba(240, 216, 120, 0.15);
}

.zjh-pos-item.active .zjh-pos-status {
  color: #00e5a0;
  background: rgba(0, 229, 160, 0.15);
}

.zjh-pos-chips {
  font-size: 20rpx;
  color: #f0d878;
  font-weight: 700;
  font-family: monospace;
}

.zjh-actions {
  flex-direction: column;
  gap: 10rpx;
  padding: 8rpx 20rpx 16rpx !important;
  background: linear-gradient(180deg, rgba(5, 20, 12, 0.5), rgba(5, 20, 12, 0.9)) !important;
  border-top: 1rpx solid rgba(198, 162, 84, 0.08) !important;
}

.zjh-actions .abtn {
  min-width: 100rpx;
  height: 72rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.actions-row {
  display: flex;
  gap: 10rpx;
  width: 100%;
}

/* 看牌按钮 */
.abtn.zjh-see {
  background: linear-gradient(135deg, #e67e22, #d35400);
  color: #fff;
  border: 1px solid rgba(230, 126, 34, 0.6);
  box-shadow: 0 0 12rpx rgba(230, 126, 34, 0.3);
}

.abtn.zjh-see:active {
  background: linear-gradient(135deg, #d35400, #e67e22);
  transform: scale(0.94);
}

.abtn.zjh-see[disabled] {
  background: rgba(230, 126, 34, 0.3);
  color: rgba(255, 255, 255, 0.4);
  border-color: rgba(230, 126, 34, 0.2);
  box-shadow: none;
}

/* 比牌按钮 */
.abtn.zjh-compare {
  background: linear-gradient(135deg, #8e44ad, #6c3483);
  color: #fff;
  border: 1px solid rgba(142, 68, 173, 0.6);
  box-shadow: 0 0 12rpx rgba(142, 68, 173, 0.3);
}

.abtn.zjh-compare:active {
  background: linear-gradient(135deg, #6c3483, #8e44ad);
  transform: scale(0.94);
}

.abtn.zjh-compare[disabled] {
  background: rgba(142, 68, 173, 0.3);
  color: rgba(255, 255, 255, 0.4);
  border-color: rgba(142, 68, 173, 0.2);
  box-shadow: none;
}

/* 手牌区聊天按钮 */
.zjh-holes-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.zjh-holes-row .my-holes {
  display: flex;
  align-items: center;
}

.zjh-holes-chat-btn {
  position: relative;
  width: 64rpx;
  height: 40rpx;
  padding: 0;
  margin: 0;
  min-width: 0;
  box-sizing: border-box;
  overflow: hidden;
  background: rgba(0, 229, 160, 0.2);
  border: 1px solid rgba(0, 229, 160, 0.4);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  flex-shrink: 0;
}

.zjh-holes-chat-btn .chat-unread-badge {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  min-width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e74c3c;
  color: #fff;
  font-size: 14rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 2rpx;
}

/* 比牌选择弹窗 */
.compare-modal {
  max-width: 520rpx;
}

.compare-list {
  max-height: 360rpx;
  overflow-y: auto;
  margin: 16rpx 0;
}

.compare-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: rgba(26, 58, 26, 0.6);
  border: 1px solid rgba(42, 90, 42, 0.4);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  transition: all 0.15s ease;
}

.compare-item:active {
  transform: scale(0.98);
}

.compare-item.selected {
  border-color: #8e44ad;
  background: rgba(142, 68, 173, 0.2);
  box-shadow: 0 0 16rpx rgba(142, 68, 173, 0.3);
}

.compare-name {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.compare-check {
  font-size: 24rpx;
}

/* 加注弹窗的暗/明提示 */
.raise-info {
  margin-bottom: 12rpx;
}

.raise-info-item {
  display: block;
  color: #8a9a8e;
  font-size: 22rpx;
  line-height: 1.8;
  text-align: left;
}

/* ============================
   比牌动画
   ============================ */

.zjh-compare-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: zjh-fade-in 0.25s ease;
}

@keyframes zjh-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.zjh-compare-anim-box {
  background: linear-gradient(145deg, #1a1a2e, #16213e);
  border: 2px solid rgba(240, 216, 120, 0.3);
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  width: 88%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 0 40rpx rgba(240, 216, 120, 0.12);
}

.zjh-compare-anim-title {
  color: #f0d878;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.zjh-compare-showdown {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  padding: 12rpx 0;
}

.zjh-compare-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.zjh-compare-player-name {
  color: #8a9a8e;
  font-size: 22rpx;
  font-weight: 600;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zjh-compare-cards {
  display: flex;
  gap: 6rpx;
  justify-content: center;
}

.zjh-compare-card-mini {
  width: 80rpx;
  height: 110rpx;
  background: linear-gradient(180deg, #fff 0%, #f5f5f0 100%);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  transition: transform 0.3s ease;
}

.zjh-compare-card-mini.flipped {
  animation: zjh-card-flip 0.4s ease;
}

@keyframes zjh-card-flip {
  0% { transform: rotateY(90deg); }
  100% { transform: rotateY(0deg); }
}

.zjh-compare-card-mini.red {
  color: #c41e3a;
}

.zjh-compare-card-mini.black {
  color: #1a1a1a;
}

.zjh-cf-v {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.zjh-cf-s {
  font-size: 26rpx;
  line-height: 1;
}

.zjh-cf-back {
  font-size: 50rpx;
  color: #c41e3a;
  opacity: 0.5;
}

.zjh-compare-hand {
  color: #f0d878;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(240, 216, 120, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  border: 1px solid rgba(240, 216, 120, 0.3);
  text-align: center;
  margin-top: 4rpx;
}

.zjh-compare-vs {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.zjh-compare-vs-text {
  color: #f0d878;
  font-size: 24rpx;
  font-weight: 700;
  animation: zjh-pulse-strong 0.8s ease infinite;
}

@keyframes zjh-pulse-strong {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
}

.zjh-compare-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  animation: zjh-result-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes zjh-result-pop {
  from { opacity: 0; transform: scale(0.5); }
  to { opacity: 1; transform: scale(1); }
}

.zjh-compare-result-icon {
  font-size: 48rpx;
}

.zjh-compare-result-text {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.zjh-compare-result-text.win {
  color: #2ecc71;
  text-shadow: 0 0 16rpx rgba(46, 204, 113, 0.5);
}

.zjh-compare-result-text.lose {
  color: #e74c3c;
  text-shadow: 0 0 16rpx rgba(231, 76, 60, 0.5);
}

.zjh-compare-result-text.draw {
  color: #f39c12;
  text-shadow: 0 0 16rpx rgba(243, 156, 18, 0.5);
}

.zjh-compare-confirm-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  animation: zjh-result-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.zjh-compare-confirm-status {
  display: flex;
  gap: 32rpx;
  margin-bottom: 8rpx;
}

.zjh-compare-confirm-status .status-item {
  font-size: 22rpx;
  color: #888;
  transition: all 0.3s;
}

.zjh-compare-confirm-status .status-item.confirmed {
  color: #4caf50;
  font-weight: 600;
}

.zjh-compare-confirm-btn {
  width: 200rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #f0d878, #d4a84b);
  color: #1a1a2e;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(240, 216, 120, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.zjh-compare-confirm-btn[disabled] {
  background: linear-gradient(135deg, #555, #444);
  color: #999;
  box-shadow: none;
}

.zjh-compare-confirm-wait {
  color: #8a9a8e;
  font-size: 20rpx;
}

.zjh-compare-close-countdown {
  color: #f0d878;
  font-size: 28rpx;
  font-weight: 700;
  animation: zjh-result-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* 聊天面板消息列表 */
.chat-msg-list {
  flex: 1;
  min-height: 200rpx;
  max-height: 400rpx;
  padding: 12rpx 16rpx;
  overflow-y: auto;
}

.chat-msg-item {
  padding: 6rpx 0;
  font-size: 22rpx;
  color: #c8d8c8;
  line-height: 1.5;
  border-bottom: 1px solid rgba(42, 90, 42, 0.2);
}

.chat-msg-item:last-child {
  border-bottom: none;
}

.chat-msg-name {
  color: #f0d878;
  font-weight: 600;
  margin-right: 6rpx;
}

.chat-msg-text {
  color: #e0e8e0;
}

.chat-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100rpx;
  color: #6a7a6a;
  font-size: 22rpx;
}

/* 结算界面弃牌玩家标签 */
.hr-card.folded {
  opacity: 0.6;
  background: rgba(30, 30, 30, 0.5);
}

.hr-folded-tag {
  font-size: 18rpx;
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  border: 1px solid rgba(231, 76, 60, 0.3);
  flex-shrink: 0;
}

.hr-chips {
  font-size: 18rpx;
  color: #8a9a8e;
  flex-shrink: 0;
}

/* 比牌中玩家头像框标识 */
.zjh-compare-badge {
  position: absolute;
  bottom: -4rpx;
  left: -4rpx;
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: #e74c3c;
  color: #fff;
  font-weight: 700;
  white-space: nowrap;
  z-index: 2;
  animation: zjh_pulse 1s ease infinite;
}

/* 战绩页面游戏类型 */
.game-type-stats {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1px solid rgba(240, 216, 120, 0.2);
}

.game-type-item {
  font-size: 22rpx;
  color: #8a9a8e;
}

/* ============================================================
   弹窗样式 (Modal) - 用于加注、比牌、重买等弹窗
   ============================================================ */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: zjh-modal-fade 0.2s ease;
}

@keyframes zjh-modal-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-box {
  background: linear-gradient(145deg, rgba(26, 42, 32, 0.98), rgba(16, 28, 22, 0.99));
  border: 2rpx solid rgba(240, 216, 120, 0.3);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  width: 88%;
  max-width: 560rpx;
  max-height: 80vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.5);
  animation: zjh-modal-pop 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes zjh-modal-pop {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.m-title {
  font-size: 32rpx;
  color: #f0d878;
  font-weight: 800;
  text-align: center;
  margin-bottom: 8rpx;
}

.m-sub {
  font-size: 24rpx;
  color: #8a9a8e;
  text-align: center;
  line-height: 1.6;
}

.m-input {
  width: 100%;
  height: 80rpx;
  background: rgba(10, 20, 16, 0.8);
  border: 1rpx solid rgba(240, 216, 120, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.m-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.m-cancel,
.m-ok {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
  padding: 0;
}

.m-cancel {
  background: rgba(100, 100, 100, 0.3);
  border: 1rpx solid rgba(150, 150, 150, 0.3);
  color: #c8c8c8;
}

.m-ok {
  background: linear-gradient(135deg, #f0d878, #d4a84b);
  color: #1a1a2e;
  box-shadow: 0 4rpx 16rpx rgba(240, 216, 120, 0.3);
}

.quick-opts {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.q-btn {
  padding: 8rpx 16rpx;
  background: rgba(26, 58, 26, 0.5);
  border: 1rpx solid rgba(100, 180, 120, 0.2);
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #b0e0c0;
  font-weight: 600;
}

.raise-hint {
  font-size: 22rpx;
  color: #8a9a8e;
  text-align: center;
}

/* ============================================================
   结算界面按钮样式 - 重新设计，与游戏整体风格协调
   ============================================================ */
.btn-confirm {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, rgba(42, 90, 42, 0.9), rgba(30, 68, 30, 0.95));
  border: 1rpx solid rgba(100, 180, 120, 0.3);
  border-radius: 20rpx;
  color: #b0e0c0;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3), 0 0 0 1rpx rgba(240, 216, 120, 0.1);
  transition: all 0.2s ease;
}

.btn-confirm:active {
  transform: scale(0.98);
}

.btn-confirm.done {
  background: rgba(50, 50, 50, 0.5);
  border-color: rgba(100, 100, 100, 0.3);
  color: #a0a0a0;
  box-shadow: none;
}

.btn-next {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #f0d878, #d4a84b);
  border: none;
  border-radius: 20rpx;
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 4rpx 20rpx rgba(240, 216, 120, 0.4);
  transition: all 0.2s ease;
}

.btn-next:active {
  transform: scale(0.98);
}

.confirm-hint {
  font-size: 20rpx;
  color: #8a9a8e;
  text-align: center;
}

.end-btn-chat {
  height: 72rpx;
}

/* 聊天面板 */
.chat-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(10, 22, 14, 0.98), rgba(5, 15, 8, 0.99));
  border-top: 1rpx solid rgba(240, 216, 120, 0.2);
  border-radius: 24rpx 24rpx 0 0;
  padding: 20rpx 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 70vh;
}

.chat-panel.show {
  transform: translateY(0);
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.chat-title {
  font-size: 28rpx;
  color: #f0d878;
  font-weight: 700;
}

.chat-close {
  font-size: 32rpx;
  color: #8a9a8e;
}

.quick-msgs {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.quick-msg {
  padding: 8rpx 16rpx;
  background: rgba(26, 58, 26, 0.5);
  border: 1rpx solid rgba(100, 180, 120, 0.2);
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #c8d8c8;
}

.chat-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: rgba(10, 20, 16, 0.8);
  border: 1rpx solid rgba(240, 216, 120, 0.15);
  border-radius: 14rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.chat-send {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #2a6a4a, #1a4a32);
  border: none;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 分享弹窗 */
.share-modal-sub {
  margin-bottom: 8rpx;
}

.share-code-wrap {
  background: rgba(10, 20, 16, 0.8);
  border: 1rpx solid rgba(240, 216, 120, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  margin: 8rpx 0;
}

.m-code {
  font-size: 48rpx;
  font-weight: 800;
  color: #f0d878;
  letter-spacing: 4rpx;
}

.m-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-copy-btn {
  background: linear-gradient(135deg, #f0d878, #d4a84b);
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.m-close {
  background: rgba(100, 100, 100, 0.3);
  border: 1rpx solid rgba(150, 150, 150, 0.3);
  color: #c8c8c8;
}

/* 聊天面板内未读徽章 */
.chat-unread-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* 结算界面滚动支持 */
.end-box {
  width: 100%;
  max-height: 100vh;
  overflow-y: auto;
  padding: 20rpx 16rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  background-color: var(--felt-deep);
}

.hand-info-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 8rpx;
  background: rgba(26, 29, 36, 0.6);
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 46, 56, 0.4);
  flex-shrink: 0;
}

.end-title {
  font-size: 32rpx;
  color: #f0d878;
  font-weight: 800;
  text-align: center;
  flex-shrink: 0;
}

/* 摊牌区优化 */
.hand-reveal {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
}

.hr-title {
  font-size: 22rpx;
  color: #8a9a8e;
  text-align: center;
  font-weight: 600;
}

.hr-card {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx;
  background: linear-gradient(135deg, rgba(20, 40, 28, 0.7), rgba(12, 28, 20, 0.85));
  border: 1rpx solid rgba(198, 162, 84, 0.15);
  border-radius: 12rpx;
  box-sizing: border-box;
  position: relative;
}

.hr-card.winner {
  border-color: #f0d878;
  background: linear-gradient(135deg, rgba(60, 50, 20, 0.7), rgba(40, 30, 15, 0.9));
  box-shadow: 0 0 16rpx rgba(240, 216, 120, 0.3);
}

.hr-av {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.hr-av-txt {
  width: 56rpx;
  height: 56rpx;
  min-width: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: rgba(26, 42, 32, 0.8);
  flex-shrink: 0;
}

.hr-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.hr-name {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hr-hand {
  font-size: 20rpx;
  color: #f0d878;
  font-weight: 600;
}

.hr-hand.win {
  color: #2ecc71;
}

.hr-cards {
  display: flex;
  gap: 4rpx;
  margin: 0 4rpx;
  flex-shrink: 0;
}

.hr-card-mini {
  width: 40rpx;
  height: 56rpx;
  border-radius: 6rpx;
  background: linear-gradient(135deg, #f5f5f5, #e0e0e0);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

.hr-card-mini.red {
  color: #c41e3a;
}

.hr-card-mini.black {
  color: #1a1a1a;
}

.hr-cv {
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
}

.hr-cs {
  font-size: 18rpx;
  line-height: 1;
  margin-top: 2rpx;
}

.hr-profit {
  font-size: 24rpx;
  font-weight: 800;
  min-width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}

.hr-profit.win {
  color: #2ecc71;
}

.hr-profit.lose {
  color: #e74c3c;
}

.hr-profit-zero {
  color: #8a9a8e;
  font-weight: 600;
}

.hr-win {
  position: absolute;
  top: 4rpx;
  right: 8rpx;
  font-size: 24rpx;
}

.hr-rebuy-icons {
  position: absolute;
  top: 4rpx;
  right: 8rpx;
  display: flex;
  gap: 2rpx;
  font-size: 14rpx;
}

/* 确认状态区优化 */
.confirm-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx;
  background: rgba(26, 29, 36, 0.5);
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 46, 56, 0.4);
  flex-shrink: 0;
}

.confirm-title {
  font-size: 22rpx;
  color: #f0d878;
  font-weight: 700;
}

.confirm-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  justify-content: center;
}

.confirm-item {
  padding: 4rpx 10rpx;
  background: rgba(26, 58, 26, 0.4);
  border: 1rpx solid rgba(42, 90, 42, 0.3);
  border-radius: 8rpx;
  font-size: 18rpx;
}

.confirm-name {
  color: #c8d8c8;
}

.confirm-ok {
  color: #2ecc71;
  font-weight: 600;
  margin-left: 4rpx;
}

.confirm-wait {
  color: #8a9a8e;
  margin-left: 4rpx;
}

/* OUT 印章 - 头像 */
.zjh-ring-out-badge {
  position: absolute;
  top: 25%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-15deg);
  font-size: 36rpx;
  font-weight: 900;
  color: rgba(231, 76, 60, 0.85);
  border: 4rpx solid rgba(231, 76, 60, 0.75);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  letter-spacing: 4rpx;
  z-index: 10;
  pointer-events: none;
}

/* 手牌区 OUT */
.zjh-hand-out {
  position: relative;
  opacity: 0.5;
}
.zjh-hand-out::after {
  content: 'OUT';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-15deg);
  font-size: 48rpx;
  font-weight: 900;
  color: rgba(231, 76, 60, 0.85);
  border: 5rpx solid rgba(231, 76, 60, 0.75);
  padding: 8rpx 24rpx;
  border-radius: 10rpx;
  letter-spacing: 6rpx;
  z-index: 10;
  pointer-events: none;
}

.zjh-my-out-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #e74c3c;
}
.zjh-my-fold-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #95a5a6;
}

/* 操作区出局变暗 */
.zjh-action-out {
  opacity: 0.35;
  pointer-events: none;
}

/* 本局战绩按钮 */
.btn-total-result {
  height: 72rpx;
  background: linear-gradient(135deg, rgba(74, 144, 226, 0.3), rgba(42, 100, 180, 0.2));
  border: 1rpx solid rgba(100, 160, 240, 0.35);
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #a0c8f0;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 4rpx;
}

/* 本局战绩弹窗 */
.total-result-modal {
  width: 90vw;
  max-width: 680rpx;
  max-height: 70vh;
  padding: 24rpx;
}

.tr-header {
  display: flex;
  align-items: center;
  padding: 12rpx 8rpx;
  background: rgba(74, 144, 226, 0.15);
  border-radius: 10rpx;
  margin: 16rpx 0 8rpx;
}

.tr-col {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.7);
}

.tr-rank {
  width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}

.tr-name {
  flex: 1;
  text-align: left;
  padding: 0 8rpx;
}

.tr-chips {
  width: 120rpx;
  text-align: right;
  flex-shrink: 0;
}

.tr-profit {
  width: 100rpx;
  text-align: right;
  flex-shrink: 0;
}

.tr-list {
  max-height: 50vh;
}

.tr-row {
  display: flex;
  align-items: center;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.tr-row.tr-me {
  background: rgba(74, 144, 226, 0.12);
  border-radius: 8rpx;
  border-bottom: 1rpx solid rgba(74, 144, 226, 0.2);
}

.tr-win {
  color: #2ecc71;
  font-weight: 700;
}

.tr-lose {
  color: #e74c3c;
  font-weight: 700;
}