/* ============================
   牌桌区域 - 围桌分布（参考德州扑克）
   ============================ */

/* 桌面环形区域容器 */
.zjh-table-wrap {
  flex: 1;
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 0;
  overflow: hidden;
  padding: 4rpx 0;
}

/* 竖椭圆牌桌 - 真实牌桌圆角矩形 + 木质边框 */
.zjh-table-oval {
  position: relative;
  width: 80%;
  flex: 1;
  min-height: 0;
  max-height: 100%;
  background: 
    radial-gradient(ellipse 90% 90% at 50% 50%,
      #1a6b3c 0%, #145a30 40%, #0d3d1f 75%, #0a2a14 100%);
  border: 8rpx solid #6b4c3b;
  border-radius: 150rpx;
  box-shadow:
    0 0 8rpx rgba(0, 0, 0, 0.4) inset,
    0 0 60rpx rgba(0, 0, 0, 0.5) inset,
    0 0 24rpx rgba(198, 162, 84, 0.15),
    inset 0 0 0 4rpx rgba(255, 255, 255, 0.04),
    inset 0 0 0 14rpx rgba(255, 255, 255, 0.02);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  z-index: 1;
  overflow: hidden;
}

/* 底池中心显示 */
.zjh-pot-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.zjh-pot-icon {
  font-size: 32rpx;
  animation: zjh-coin-bounce 1.5s ease infinite;
}

@keyframes zjh-coin-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.zjh-pot-amount {
  font-size: 48rpx;
  font-weight: 800;
  color: #f0d878;
  text-shadow: 
    0 0 20rpx rgba(240, 216, 120, 0.6),
    0 0 40rpx rgba(240, 216, 120, 0.3),
    0 2rpx 10rpx rgba(240, 216, 120, 0.5);
  line-height: 1;
  transition: all 0.3s ease;
}

.zjh-pot-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #f0d878;
  text-shadow: 
    0 0 20rpx rgba(240, 216, 120, 0.6),
    0 0 40rpx rgba(240, 216, 120, 0.3),
    0 2rpx 10rpx rgba(240, 216, 120, 0.5);
  line-height: 1;
  transition: all 0.3s ease;
}

.zjh-pot-amount.changed {
  animation: zjh-pot-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.zjh-pot-num.changed {
  animation: zjh-pot-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes zjh-pot-pop {
  0% { transform: scale(1); }
  50% { transform: scale(1.25); color: #ffeaa7; }
  100% { transform: scale(1); }
}

/* 封顶进度条 */
.zjh-cap-progress {
  width: 70%;
  max-width: 300rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 5rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-shadow: inset 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}

.zjh-cap-progress-bar {
  flex: 1;
  height: 100%;
  background: linear-gradient(90deg, #27ae60, #f39c12, #e74c3c);
  border-radius: 5rpx;
  transition: width 0.4s ease;
  box-shadow: 0 0 8rpx rgba(46, 204, 113, 0.4);
}

.zjh-cap-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.45);
  white-space: nowrap;
  flex-shrink: 0;
}

/* 牌桌内阶段信息 */
.zjh-phase-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.zjh-phase-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.zjh-countdown-txt {
  font-size: 26rpx;
  color: #f0d878;
  font-weight: 700;
  animation: zjh_pulse 1s ease infinite;
}

.zjh-waiting-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 牌桌水印 */
.zjh-table-watermark {
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  opacity: 0.35;
  pointer-events: none;
}

.zjh-watermark-desc {
  font-size: 18rpx;
