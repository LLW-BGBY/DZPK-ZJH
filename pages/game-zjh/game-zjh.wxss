/* ============================
   炸金花 游戏页面样式 - 独立完整版
   ============================ */

/* 小程序页面根元素 - 必须设置，否则子元素 height: 100% 不生效 */
page {
  height: 100%;
  width: 100%;
  background-color: #0a1a0f;
}

/* ============================================================
   基础布局 & 加载/错误/过渡
   ============================================================ */

/* 根容器 - 使用 100vh 确保充满屏幕 */
.zjh-root {
  width: 100%;
  height: 100vh;
  background-color: #0a1a0f;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  box-sizing: border-box;
  overflow: hidden;
}

/* 游戏主界面 - flex 列布局确保操作按钮始终可见 */
.zjh-game {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #0a1a0f;
  overflow: hidden;
}

.loading {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #a0a6b0;
}

.error-box {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: #a0a6b0;
  font-size: 28rpx;
}

.btn-sm {
  background: rgba(240, 216, 120, 0.12);
  color: #f0d878;
  border: 1rpx solid rgba(240, 216, 120, 0.3);
  border-radius: 20rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  margin: 6rpx;
}

.transition-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.transition-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.transition-icon {
  font-size: 80rpx;
  animation: bounce 1s ease infinite;
}

.transition-title {
  font-size: 32rpx;
  color: #f0d878;
  font-weight: 700;
}

.transition-sub {
  font-size: 24rpx;
  color: #8a9a8e;
}

/* ============================================================
   等待界面
   ============================================================ */
.wait-area {
  width: 100%;
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wait-room-card {
  width: 100%;
  background: #1a1d24;
  border: 2rpx solid #2a2e38;
  border-radius: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.wait-room-compact-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.wait-room-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.wait-room-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.wait-room-lock {
  font-size: 24rpx;
}

.wait-room-num-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #252830;
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
}

.wait-room-num {
  font-size: 26rpx;
  color: #a0a6b0;
  font-family: monospace;
}

.wait-room-copy {
  font-size: 22rpx;
  color: #60b8ff;
}

.wait-room-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  font-size: 24rpx;
  color: #a0a6b0;
  margin-bottom: 24rpx;
}

.wait-meta-dot {
  color: #4a4f5a;
}

.wait-action-row {
  display: flex;
  gap: 16rpx;
}

.wait-action-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  padding: 0;
  border: none;
}

.wait-action-invite {
  background: #1e3a5f;
  color: #60b8ff;
}

.wait-action-leave {
  background: #3a1e20;
  color: #ff6b6b;
}

.wait-action-icon {
  font-size: 28rpx;
}

.wait-action-label {
  font-size: 26rpx;
}

.wait-section-title {
  font-size: 26rpx;
  color: #8a9a8e;
  font-weight: 600;
  margin-bottom: 16rpx;
  align-self: flex-start;
}

.wait-list {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.wait-card {
  width: calc(33.33% - 12rpx);
  background: #1a1d24;
  border: 2rpx solid #2a2e38;
  border-radius: 18rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.wait-card.ready {
  border-color: #2a6a4a;
}

.wait-card.bust {
  opacity: 0.5;
}

.wait-card.empty {
  background: rgba(26, 29, 36, 0.5);
  border-style: dashed;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2px solid rgba(198, 162, 84, 0.4);
}

.avatar-txt {
  font-size: 36rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(26, 58, 26, 0.8);
  border: 2px solid rgba(198, 162, 84, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.name {
  font-size: 24rpx;
  color: #d1d5db;
  font-weight: 600;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chips {
  font-size: 22rpx;
  color: #f0d878;
  font-weight: 700;
}

.bust {
  font-size: 22rpx;
  color: #e74c3c;
  font-weight: 600;
}

.ready-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  background: rgba(42, 74, 54, 0.5);
  color: #8a9a8e;
  border: 1rpx solid rgba(42, 90, 42, 0.3);
}

.ready-badge.done {
  background: rgba(46, 204, 113, 0.15);
  color: #2ecc71;
  border-color: rgba(46, 204, 113, 0.3);
}

.wait-chat-log {
  width: 100%;
  margin-bottom: 24rpx;
}

.wait-chat-title {
  font-size: 24rpx;
  color: #8a9a8e;
  margin-bottom: 8rpx;
}

.wait-chat-scroll {
  max-height: 160rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  padding: 8rpx 12rpx;
}

.wait-chat-item {
  padding: 3rpx 0;
  font-size: 22rpx;
  line-height: 1.5;
}

.wait-chat-name {
  color: #00ffb3;
  font-weight: 700;
}

.wait-chat-text {
  color: rgba(255, 255, 255, 0.7);
}

/* 等待界面按钮 */
.btn-ready {
  width: 100%;
  height: 88rpx;
  background: #2a4a36;
  border-radius: 20rpx;
  color: #39e060;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: none;
  padding: 0;
}

.btn-ready.done {
  background: #1e3a28;
  color: #a0a6b0;
}

.btn-rebuy {
  width: 100%;
  height: 80rpx;
  background: rgba(240, 216, 120, 0.12);
  border: 1rpx solid rgba(240, 216, 120, 0.3);
  border-radius: 20rpx;
  color: #f0d878;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  padding: 0;
}

.btn-chat {
  width: 100%;
  height: 80rpx;
  background: rgba(26, 58, 26, 0.6);
  border: 1rpx solid rgba(42, 90, 42, 0.4);
  border-radius: 20rpx;
  color: #c8d8c8;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  position: relative;
  padding: 0;
}

.chat-unread-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #e74c3c;
  color: #fff;
  font-size: 16rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
}

.btn-start {
  width: 100%;
  height: 88rpx;
  background: #1e3a5f;
  border-radius: 20rpx;
  color: #60b8ff;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: none;
  padding: 0;
}

.inline-countdown {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx;
  background: rgba(240, 216, 120, 0.08);
  border-radius: 14rpx;
  border: 1rpx solid rgba(240, 216, 120, 0.15);
  margin-bottom: 12rpx;
}

.inline-countdown-icon {
  font-size: 28rpx;
}

.inline-countdown-label {
  font-size: 24rpx;
  color: #f0d878;
  font-weight: 600;
}

.countdown-cancel-btn {
  background: rgba(231, 76, 60, 0.2);
  border: 1rpx solid rgba(231, 76, 60, 0.3);
  border-radius: 10rpx;
  color: #e74c3c;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  margin-left: 12rpx;
}

/* ============================================================
   游戏界面 - 本玩家区域
   ============================================================ */
.game-my-section {
  width: 100%;
  padding: 8rpx 20rpx 16rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(180deg, rgba(10, 31, 18, 0.3), rgba(5, 20, 12, 0.6));
  border-top: 1rpx solid rgba(198, 162, 84, 0.1);
}

.my-info-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 8rpx 14rpx;
  background: rgba(26, 58, 26, 0.5);
  border: 1px solid rgba(198, 162, 84, 0.12);
  border-radius: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.my-call {
  font-size: 22rpx;
  color: #f0d878;
  font-weight: 600;
}

.my-turn {
  font-size: 22rpx;
  color: #00e5a0;
  font-weight: 700;
  animation: pulse 1s ease infinite;
}

.my-holes {
  display: flex;
  align-items: center;
  gap: 12rpx;
  position: relative;
}

.hcard {
  width: 80rpx;
  height: 110rpx;
  border-radius: 10rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border: 2rpx solid rgba(198, 162, 84, 0.3);
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.35);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.hcard.red {
  color: #c41e3a;
}

.hcard.black {
  color: #1a1a1a;
}

.hv {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.hs {
  font-size: 30rpx;
  line-height: 1;
  margin-top: 2rpx;
  font-weight: 700;
}

/* ============================================================
   操作按钮区
   ============================================================ */
.actions {
  width: 100%;
  padding: 8rpx 20rpx 20rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  background: linear-gradient(180deg, rgba(5, 20, 12, 0.6), rgba(5, 20, 12, 0.95));
  border-top: 1rpx solid rgba(198, 162, 84, 0.1);
}

.actions-row {
  display: flex;
  gap: 10rpx;
  width: 100%;
}

.abtn {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(26, 58, 26, 0.6);
  padding: 0;
  transition: all 0.15s ease;
}

.abtn:active {
  transform: scale(0.95);
}

.abtn[disabled] {
  opacity: 0.5;
}

.abtn.fold {
  background: linear-gradient(180deg, rgba(42, 74, 122, 0.8), rgba(30, 58, 95, 0.9));
  border-color: rgba(100, 140, 180, 0.2);
}

.abtn.call {
  background: linear-gradient(180deg, rgba(46, 100, 62, 0.8), rgba(32, 72, 44, 0.9));
  border-color: rgba(100, 180, 120, 0.2);
}

.abtn.raise {
  background: linear-gradient(180deg, rgba(122, 61, 61, 0.8), rgba(90, 42, 42, 0.9));
  border-color: rgba(200, 120, 120, 0.2);
}

.abtn.allin {
  background: linear-gradient(135deg, #c41e3a, #8b0000);
  border-color: rgba(255, 60, 60, 0.4);
  box-shadow: 0 0 16rpx rgba(196, 30, 58, 0.3);
}

.abtn.done {
  background: rgba(42, 90, 42, 0.4) !important;
  border-color: rgba(46, 204, 113, 0.3) !important;
  color: #2ecc71 !important;
}

/* ============================================================
   结算界面
   ============================================================ */
.end-box {
  width: 100%;
  padding: 24rpx 20rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hand-info-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 10rpx;
  background: rgba(26, 29, 36, 0.6);
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 46, 56, 0.4);
}

.hand-info-text {
  font-size: 24rpx;
  color: #a0a6b0;
  font-weight: 600;
}

.hand-info-final {
  font-size: 22rpx;
  color: #f0d878;
  font-weight: 700;
  background: rgba(240, 216, 120, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.end-title {
  font-size: 36rpx;
  color: #f0d878;
  font-weight: 800;
  text-align: center;
}

/* 实时聊天 */
.game-live-chat {
  width: 100%;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  overflow: hidden;
}

.live-chat-scroll {
  max-height: 120rpx;
  padding: 8rpx 12rpx;
}

.live-chat-item {
  padding: 3rpx 0;
  font-size: 22rpx;
  line-height: 1.5;
}

.live-chat-name {
  color: #00ffb3;
  font-weight: 700;
}

.live-chat-text {
  color: rgba(255, 255, 255, 0.7);
}

/* 摊牌 */
.hand-reveal {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hr-title {
  font-size: 28rpx;
  color: #f0d878;
  font-weight: 700;
  text-align: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(240, 216, 120, 0.15);
}

.hr-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx;
  background: rgba(26, 29, 36, 0.8);
  border: 1rpx solid rgba(42, 46, 56, 0.5);
  border-radius: 16rpx;
  position: relative;
}

.hr-card.winner {
  border-color: rgba(240, 216, 120, 0.5);
  background: rgba(30, 45, 30, 0.8);
  box-shadow: 0 0 20rpx rgba(240, 216, 120, 0.15);
}

.hr-card.folded {
  opacity: 0.5;
  background: rgba(30, 30, 30, 0.5);
}

.hr-av {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2px solid rgba(198, 162, 84, 0.4);
  flex-shrink: 0;
}

.hr-av-txt {
  font-size: 32rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(26, 58, 26, 0.8);
  border: 2px solid rgba(198, 162, 84, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hr-rebuy-icons {
  position: absolute;
  right: 8rpx;
  top: 6rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  font-size: 16rpx;
  line-height: 1.2;
}

.hr-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hr-name {
  font-size: 24rpx;
  color: #d1d5db;
  font-weight: 700;
}

.hr-hand {
  font-size: 22rpx;
  color: #8a9a8e;
}

.hr-hand.win {
  color: #f0d878;
  font-weight: 700;
}

.hr-score-box {
  flex-shrink: 0;
}

.hr-profit {
  font-size: 28rpx;
  font-weight: 800;
}

.hr-profit.win {
  color: #2ecc71;
}

.hr-profit.lose {
  color: #e74c3c;
}

.hr-profit-zero {
  color: #8a9a8e;
}

.hr-cards {
  display: flex;
  gap: 4rpx;
  flex-shrink: 0;
}

.hr-card-mini {
  width: 48rpx;
  height: 66rpx;
  border-radius: 6rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f0f0f0 100%);
  border: 1rpx solid rgba(198, 162, 84, 0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

.hr-card-mini.red {
  color: #c41e3a;
}

.hr-card-mini.black {
  color: #1a1a1a;
}

.hr-cv {
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.hr-cs {
  font-size: 18rpx;
  line-height: 1;
}

.hr-win {
  font-size: 36rpx;
  flex-shrink: 0;
}

/* 确认继续 */
.confirm-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(26, 29, 36, 0.5);
  border-radius: 16rpx;
  border: 1rpx solid rgba(42, 46, 56, 0.4);
}

.confirm-title {
  font-size: 26rpx;
  color: #f0d878;
  font-weight: 700;
}

.confirm-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: center;
}

.confirm-item {
  padding: 6rpx 14rpx;
  background: rgba(26, 58, 26, 0.4);
  border: 1rpx solid rgba(42, 90, 42, 0.3);
  border-radius: 10rpx;
}

.confirm-name {
  font-size: 22rpx;
  color: #a0a6b0;
}

/* ============================================================
   炸金花特有样式
   ============================================================ */

/* 暗牌卡背样式（对齐德州扑克白底卡牌，暗牌时显示蓝底花纹） */
.zjh-card-dark {
  background: linear-gradient(135deg, #1a3a5c, #2a5298) !important;
  border: 2px solid rgba(200, 180, 100, 0.5) !important;
  color: transparent !important;
  position: relative;
  overflow: hidden;
}

.zjh-card-back-pattern {
  width: 100%;
  height: 100%;
  background: 
    repeating-linear-gradient(45deg, transparent, transparent 4rpx, rgba(255,255,255,0.08) 4rpx, rgba(255,255,255,0.08) 8rpx),
    repeating-linear-gradient(-45deg, transparent, transparent 4rpx, rgba(255,255,255,0.08) 4rpx, rgba(255,255,255,0.08) 8rpx);
  border-radius: 10rpx;
  position: relative;
}

.zjh-card-back-pattern::after {
  content: '🂠';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  color: rgba(255,255,255,0.3);
}

/* 游戏类型标签 */
.zjh-game-type-badge {
  background: linear-gradient(135deg, #e67e22, #d35400);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  letter-spacing: 1rpx;
}

/* 暗/明状态标签 — 与 D 徽章完全相同结构 */
.zjh-status-dark {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  background: #2c3e50;
  color: #bdc3c7;
  font-size: 14rpx;
  font-weight: 700;
  min-width: 26rpx;
  height: 26rpx;
  line-height: 26rpx;
  padding: 0 4rpx;
  border-radius: 6rpx;
  border: 1px solid #34495e;
