  border-radius: 6rpx;
}

.zjh-hand-card-value {
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.1;
}

.zjh-hand-card-suit {
  font-size: 18rpx;
  line-height: 1.1;
}

.zjh-myhand-chat-btn {
  position: relative;
  width: 48rpx;
  height: 36rpx;
  padding: 0;
  margin: 0;
  min-width: 0;
  box-sizing: border-box;
  overflow: hidden;
  background: rgba(0, 229, 160, 0.2);
  border: 1px solid rgba(0, 229, 160, 0.4);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  line-height: 1;
  flex-shrink: 0;
}

/* ============================
   操作按钮区 - 参考德州扑克
   ============================ */
.zjh-action-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 4rpx 12rpx;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
  z-index: 10;
  flex-shrink: 0;
}

.zjh-action-row {
  display: flex;
  gap: 8rpx;
  width: 100%;
}

.zjh-action-btn {
  flex: 1;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  transition: all 0.15s ease;
  border: none;
}

.zjh-action-btn:active {
  transform: scale(0.96);
}

.zjh-action-btn.action-fold {
  background: linear-gradient(180deg, rgba(42, 74, 122, 0.8), rgba(30, 58, 95, 0.9));
  border: 1px solid rgba(100, 140, 180, 0.2);
  color: #b0c8e0;
}

.zjh-action-btn.action-see {
  background: linear-gradient(180deg, rgba(122, 90, 42, 0.8), rgba(95, 65, 30, 0.9));
  border: 1px solid rgba(180, 150, 100, 0.2);
  color: #e0c890;
}

.zjh-action-btn.action-call {
  background: linear-gradient(180deg, rgba(46, 100, 62, 0.8), rgba(32, 72, 44, 0.9));
  border: 1px solid rgba(100, 180, 120, 0.2);
  color: #b0e0c0;
}

.zjh-action-btn.action-raise {
  background: linear-gradient(180deg, rgba(122, 61, 61, 0.8), rgba(90, 42, 42, 0.9));
  border: 1px solid rgba(200, 120, 120, 0.2);
  color: #e0b0b0;
}

.zjh-action-btn.action-compare {
  background: linear-gradient(180deg, rgba(100, 70, 20, 0.8), rgba(70, 50, 15, 0.9));
  border: 1px solid rgba(180, 140, 60, 0.2);
  color: #e0c880;
}

.zjh-action-btn.action-allin {
  background: linear-gradient(180deg, rgba(140, 30, 30, 0.8), rgba(100, 20, 20, 0.9));
  border: 1px solid rgba(220, 80, 80, 0.2);
  color: #ffb0b0;
}

.zjh-action-btn.done {
  opacity: 0.5;
  filter: grayscale(0.3);
}

/* 信息行 - 聊天 + 日志上下排列 */
.zjh-info-row {
  padding: 0 12rpx;
  margin-top: 6rpx;
}

.zjh-chat-scroll {
  max-height: 80rpx;
  padding: 6rpx 10rpx;
  background: rgba(10, 31, 18, 0.25);
  border-radius: 10rpx;
}

.zjh-chat-item {
  display: flex;
  gap: 6rpx;
  line-height: 1.6;
  font-size: 20rpx;
}

.zjh-chat-name {
  color: #00ffb3;
  font-weight: 700;
  flex-shrink: 0;
  font-size: 20rpx;
}

.zjh-chat-text {
  color: rgba(255, 255, 255, 0.8);
  word-break: break-all;
  font-size: 20rpx;
}



/* 牌桌内日志 */
.zjh-table-log {
  max-height: 130rpx;
  width: 85%;
  padding: 6rpx 10rpx;
  margin-top: 6rpx;
  background: rgba(0, 0, 0, 0.15);
  border-radius: 8rpx;
}

.zjh-table-log-item {
  line-height: 1.7;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
  padding: 2rpx 0;
}

.zjh-table-log-item.system {
  color: rgba(255, 255, 255, 0.45);
}

.zjh-table-log-item.action {
  color: rgba(255, 255, 255, 0.85);
}

.zjh-table-log-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  color: rgba(255, 255, 255, 0.35);
  font-size: 20rpx;
}

@keyframes zjh_pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ============================
   游戏头部精简
   ============================ */
.zjh-game-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 16rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.1) 100%);
  border-bottom: 1px solid rgba(198, 162, 84, 0.1);
  gap: 8rpx;
  flex-shrink: 0;
}

.zjh-gh-left {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.zjh-gh-num {
  font-size: 24rpx;
  color: rgba(0, 229, 160, 0.9);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.zjh-gh-copy {
  font-size: 16rpx;
  color: rgba(0, 229, 160, 0.55);
  border: 1px solid rgba(0, 229, 160, 0.25);
  border-radius: 4rpx;
  padding: 1rpx 8rpx;
}

.zjh-gh-mid {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.zjh-gh-info {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.zjh-gh-info.zjh-cap-warning {
  color: #e74c3c;
  font-weight: 700;
  animation: zjh_pulse 1s ease infinite;
}

.zjh-gh-sep {
  color: rgba(255, 255, 255, 0.12);
  font-size: 16rpx;
}

.zjh-gh-badge {
  background: linear-gradient(135deg, rgba(198, 162, 84, 0.3), rgba(198, 162, 84, 0.1));
  border: 1px solid rgba(198, 162, 84, 0.35);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  font-size: 20rpx;
  color: #e0c878;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.zjh-gh-right {
  flex-shrink: 0;
}

.zjh-gh-leave {
  font-size: 28rpx;
  padding: 2rpx 6rpx;
  opacity: 0.65;
}

/* ============================================================
   横向玩家状态条
   ============================================================ */
.zjh-pos-bar {
  width: 100%;
  white-space: nowrap;
  padding: 8rpx 12rpx;
  background: rgba(10, 20, 15, 0.85);
  border-bottom: 1rpx solid rgba(198, 162, 84, 0.12);
  box-sizing: border-box;
  flex-shrink: 0;
}

.zjh-pos-bar::-webkit-scrollbar {
  display: none;
}

.zjh-pos-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  margin-right: 8rpx;
  background: rgba(26, 58, 26, 0.4);
  border: 1rpx solid rgba(42, 90, 42, 0.2);
  border-radius: 10rpx;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.zjh-pos-item.active {
  background: rgba(0, 229, 160, 0.15);
  border-color: #00e5a0;
  box-shadow: 0 0 12rpx rgba(0, 229, 160, 0.3);
}

.zjh-pos-item.folded {
  opacity: 0.45;
  background: rgba(40, 40, 40, 0.4);
  border-color: rgba(80, 80, 80, 0.2);
}

.zjh-pos-item.busted {
  opacity: 0.4;
  background: rgba(60, 20, 20, 0.4);
  border-color: rgba(120, 40, 40, 0.2);
}

.zjh-pos-name {
  font-size: 22rpx;
  color: #d1d5db;
  font-weight: 600;
}

.zjh-pos-item.active .zjh-pos-name {
  color: #00e5a0;
}

.zjh-pos-status {
  font-size: 18rpx;
  color: #8a9a8e;
  padding: 2rpx 8rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 6rpx;
}

.zjh-pos-status.dealer {
  color: #f0d878;
  background: rgba(240, 216, 120, 0.15);
}

.zjh-pos-item.active .zjh-pos-status {
  color: #00e5a0;
  background: rgba(0, 229, 160, 0.15);
}

.zjh-pos-chips {
  font-size: 20rpx;
  color: #f0d878;
  font-weight: 700;
  font-family: monospace;
}

.zjh-actions {
  flex-direction: column;
  gap: 10rpx;
  padding: 8rpx 20rpx 16rpx !important;
  background: linear-gradient(180deg, rgba(5, 20, 12, 0.5), rgba(5, 20, 12, 0.9)) !important;
  border-top: 1rpx solid rgba(198, 162, 84, 0.08) !important;
}

.zjh-actions .abtn {
  min-width: 100rpx;
  height: 72rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.actions-row {
  display: flex;
  gap: 10rpx;
  width: 100%;
}

/* 看牌按钮 */
.abtn.zjh-see {
  background: linear-gradient(135deg, #e67e22, #d35400);
  color: #fff;
  border: 1px solid rgba(230, 126, 34, 0.6);
  box-shadow: 0 0 12rpx rgba(230, 126, 34, 0.3);
}

.abtn.zjh-see:active {
  background: linear-gradient(135deg, #d35400, #e67e22);
  transform: scale(0.94);
}

.abtn.zjh-see[disabled] {
  background: rgba(230, 126, 34, 0.3);
  color: rgba(255, 255, 255, 0.4);
  border-color: rgba(230, 126, 34, 0.2);
  box-shadow: none;
}

/* 比牌按钮 */
.abtn.zjh-compare {
  background: linear-gradient(135deg, #8e44ad, #6c3483);
  color: #fff;
  border: 1px solid rgba(142, 68, 173, 0.6);
  box-shadow: 0 0 12rpx rgba(142, 68, 173, 0.3);
}

.abtn.zjh-compare:active {
  background: linear-gradient(135deg, #6c3483, #8e44ad);
  transform: scale(0.94);
}

.abtn.zjh-compare[disabled] {
  background: rgba(142, 68, 173, 0.3);
  color: rgba(255, 255, 255, 0.4);
  border-color: rgba(142, 68, 173, 0.2);
  box-shadow: none;
}

/* 手牌区聊天按钮 */
.zjh-holes-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.zjh-holes-row .my-holes {
  display: flex;
  align-items: center;
}

.zjh-holes-chat-btn {
  position: relative;
  width: 64rpx;
  height: 40rpx;
  padding: 0;
  margin: 0;
  min-width: 0;
  box-sizing: border-box;
  overflow: hidden;
  background: rgba(0, 229, 160, 0.2);
  border: 1px solid rgba(0, 229, 160, 0.4);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  flex-shrink: 0;
}

.zjh-holes-chat-btn .chat-unread-badge {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  min-width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e74c3c;
  color: #fff;
  font-size: 14rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 2rpx;
}

/* 比牌选择弹窗 */
.compare-modal {
  max-width: 520rpx;
}

.compare-list {
  max-height: 360rpx;
  overflow-y: auto;
  margin: 16rpx 0;
}

.compare-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: rgba(26, 58, 26, 0.6);
  border: 1px solid rgba(42, 90, 42, 0.4);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  transition: all 0.15s ease;
}

.compare-item:active {
  transform: scale(0.98);
}

.compare-item.selected {
  border-color: #8e44ad;
  background: rgba(142, 68, 173, 0.2);
  box-shadow: 0 0 16rpx rgba(142, 68, 173, 0.3);
}

.compare-name {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.compare-check {
  font-size: 24rpx;
}

/* 加注弹窗的暗/明提示 */
.raise-info {
  margin-bottom: 12rpx;
}

.raise-info-item {
  display: block;
  color: #8a9a8e;
  font-size: 22rpx;
  line-height: 1.8;
  text-align: left;
}

/* ============================
   比牌动画
   ============================ */

.zjh-compare-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: zjh-fade-in 0.25s ease;
}

@keyframes zjh-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.zjh-compare-anim-box {
  background: linear-gradient(145deg, #1a1a2e, #16213e);
  border: 2px solid rgba(240, 216, 120, 0.3);
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  width: 88%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 0 40rpx rgba(240, 216, 120, 0.12);
}

.zjh-compare-anim-title {
  color: #f0d878;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.zjh-compare-showdown {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  padding: 12rpx 0;
}

.zjh-compare-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.zjh-compare-player-name {
  color: #8a9a8e;
  font-size: 22rpx;
  font-weight: 600;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zjh-compare-cards {
  display: flex;
  gap: 6rpx;
  justify-content: center;
}

.zjh-compare-card-mini {
  width: 80rpx;
  height: 110rpx;
  background: linear-gradient(180deg, #fff 0%, #f5f5f0 100%);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  transition: transform 0.3s ease;
}

.zjh-compare-card-mini.flipped {
  animation: zjh-card-flip 0.4s ease;
}

@keyframes zjh-card-flip {
  0% { transform: rotateY(90deg); }
  100% { transform: rotateY(0deg); }
}

.zjh-compare-card-mini.red {
  color: #c41e3a;
}

.zjh-compare-card-mini.black {
  color: #1a1a1a;
}

.zjh-cf-v {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.zjh-cf-s {
  font-size: 26rpx;
  line-height: 1;
}

.zjh-cf-back {
  font-size: 50rpx;
  color: #c41e3a;
  opacity: 0.5;
}

.zjh-compare-hand {
  color: #f0d878;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(240, 216, 120, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  border: 1px solid rgba(240, 216, 120, 0.3);
  text-align: center;
  margin-top: 4rpx;
}

.zjh-compare-vs {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.zjh-compare-vs-text {
  color: #f0d878;
  font-size: 24rpx;
  font-weight: 700;
  animation: zjh-pulse-strong 0.8s ease infinite;
}

@keyframes zjh-pulse-strong {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
}

.zjh-compare-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  animation: zjh-result-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes zjh-result-pop {
  from { opacity: 0; transform: scale(0.5); }
  to { opacity: 1; transform: scale(1); }
}

.zjh-compare-result-icon {
  font-size: 48rpx;
}

.zjh-compare-result-text {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.zjh-compare-result-text.win {
  color: #2ecc71;
  text-shadow: 0 0 16rpx rgba(46, 204, 113, 0.5);
}

.zjh-compare-result-text.lose {
  color: #e74c3c;
  text-shadow: 0 0 16rpx rgba(231, 76, 60, 0.5);
}

.zjh-compare-result-text.draw {
  color: #f39c12;
  text-shadow: 0 0 16rpx rgba(243, 156, 18, 0.5);
}

.zjh-compare-confirm-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  animation: zjh-result-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.zjh-compare-confirm-status {
  display: flex;
  gap: 32rpx;
  margin-bottom: 8rpx;
}

.zjh-compare-confirm-status .status-item {
  font-size: 22rpx;
  color: #888;
  transition: all 0.3s;
}

.zjh-compare-confirm-status .status-item.confirmed {
  color: #4caf50;
  font-weight: 600;
}

.zjh-compare-confirm-btn {
  width: 200rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #f0d878, #d4a84b);
  color: #1a1a2e;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(240, 216, 120, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.zjh-compare-confirm-btn[disabled] {
  background: linear-gradient(135deg, #555, #444);
  color: #999;
  box-shadow: none;
}

.zjh-compare-confirm-wait {
  color: #8a9a8e;
  font-size: 20rpx;
}

.zjh-compare-close-countdown {
  color: #f0d878;
  font-size: 28rpx;
  font-weight: 700;
  animation: zjh-result-pop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* 聊天面板消息列表 */
.chat-msg-list {
  flex: 1;
  min-height: 200rpx;
  max-height: 400rpx;
  padding: 12rpx 16rpx;
  overflow-y: auto;
}

.chat-msg-item {
  padding: 6rpx 0;
  font-size: 22rpx;
  color: #c8d8c8;
  line-height: 1.5;
  border-bottom: 1px solid rgba(42, 90, 42, 0.2);
}

.chat-msg-item:last-child {
  border-bottom: none;
}

.chat-msg-name {
  color: #f0d878;
  font-weight: 600;
  margin-right: 6rpx;
}

.chat-msg-text {
  color: #e0e8e0;
}

.chat-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100rpx;
  color: #6a7a6a;
  font-size: 22rpx;
}

/* 结算界面弃牌玩家标签 */
.hr-card.folded {
  opacity: 0.6;
  background: rgba(30, 30, 30, 0.5);
}

.hr-folded-tag {
  font-size: 18rpx;
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.15);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  border: 1px solid rgba(231, 76, 60, 0.3);
  flex-shrink: 0;
}

.hr-chips {
  font-size: 18rpx;
  color: #8a9a8e;
  flex-shrink: 0;
}

/* 比牌中玩家头像框标识 */
.zjh-compare-badge {
  position: absolute;
  bottom: -4rpx;
  left: -4rpx;
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: #e74c3c;
  color: #fff;
  font-weight: 700;
  white-space: nowrap;
  z-index: 2;
  animation: zjh_pulse 1s ease infinite;
}

/* 战绩页面游戏类型 */
.game-type-stats {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1px solid rgba(240, 216, 120, 0.2);
}

.game-type-item {
  font-size: 22rpx;
  color: #8a9a8e;
}