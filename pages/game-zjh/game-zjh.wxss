  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

.hr-card-mini.red {
  color: #c41e3a;
}

.hr-card-mini.black {
